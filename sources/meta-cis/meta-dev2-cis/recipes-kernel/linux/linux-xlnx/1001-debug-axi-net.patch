From c9823c50f07612fd74732276532d39acebce3129 Mon Sep 17 00:00:00 2001
From: Fan Wu <fan.wu@zillnk.com>
Date: Thu, 4 Sep 2025 07:22:20 +0000
Subject: [PATCH] debug axi-net

---
 .../net/ethernet/xilinx/xilinx_axienet_main.c | 62 +++++++++++++++----
 1 file changed, 50 insertions(+), 12 deletions(-)

diff --git a/drivers/net/ethernet/xilinx/xilinx_axienet_main.c b/drivers/net/ethernet/xilinx/xilinx_axienet_main.c
index 3c31fd8caf41..8d1d79672c1f 100644
--- a/drivers/net/ethernet/xilinx/xilinx_axienet_main.c
+++ b/drivers/net/ethernet/xilinx/xilinx_axienet_main.c
@@ -566,8 +566,10 @@ void __axienet_device_reset(struct axienet_dma_q *q)
 	 * Note that even though both TX and RX have their own reset register,
 	 * they both reset the entire DMA core, so only one needs to be used.
 	 */
+	printk("--------wufan------ %s: Enter function\n", __func__);
 	axienet_dma_out32(q, XAXIDMA_TX_CR_OFFSET, XAXIDMA_CR_RESET_MASK);
 	timeout = DELAY_OF_ONE_MILLISEC;
+	printk("--------wufan------ %s: Enter axienet_dma_in32\n", __func__);
 	while (axienet_dma_in32(q, XAXIDMA_TX_CR_OFFSET) &
 				XAXIDMA_CR_RESET_MASK) {
 		udelay(1);
@@ -577,6 +579,7 @@ void __axienet_device_reset(struct axienet_dma_q *q)
 			break;
 		}
 	}
+	printk("--------wufan------ %s: Exit function\n", __func__);
 }
 
 /**
@@ -602,23 +605,29 @@ static int axienet_device_reset(struct net_device *ndev)
 	struct axienet_dma_q *q;
 	u32 i;
 	u8 maj, minor;
-
+	printk("--------wufan------ %s: Enter function\n", __func__);
 	if (lp->axienet_config->mactype == XAXIENET_10G_25G ||
 	    lp->axienet_config->mactype == XAXIENET_1G_10G_25G) {
 		/* Reset the XXV MAC */
+		printk("--------wufan------ %s: Enter axienet_ior(lp, XXV_GT_RESET_OFFSET)\n", __func__);
 		val = axienet_ior(lp, XXV_GT_RESET_OFFSET);
 		val |= XXV_GT_RESET_MASK;
+		printk("--------wufan------ %s: Enter axienet_iow(lp, XXV_GT_RESET_OFFSET, val)\n", __func__);
 		axienet_iow(lp, XXV_GT_RESET_OFFSET, val);
 		/* Wait for 1ms for GT reset to complete as per spec */
 		mdelay(1);
+		printk("--------wufan------ %s: Enter axienet_ior(lp, XXV_GT_RESET_OFFSET)\n", __func__);
 		val = axienet_ior(lp, XXV_GT_RESET_OFFSET);
 		val &= ~XXV_GT_RESET_MASK;
+		printk("--------wufan------ %s: Enter axienet_iow(lp, XXV_GT_RESET_OFFSET, val)\n", __func__);
 		axienet_iow(lp, XXV_GT_RESET_OFFSET, val);
 	}
 
 	if (lp->axienet_config->mactype == XAXIENET_MRMAC) {
 		/* Reset MRMAC */
+		printk("--------wufan------ %s: Enter axienet_mrmac_reset\n", __func__);
 		axienet_mrmac_reset(lp);
+		printk("--------wufan------ %s: Enter axienet_mrmac_gt_reset\n", __func__);
 		err = axienet_mrmac_gt_reset(ndev);
 		if (err)
 			return err;
@@ -626,6 +635,7 @@ static int axienet_device_reset(struct net_device *ndev)
 
 	for_each_rx_dma_queue(lp, i) {
 		q = lp->dq[i];
+		printk("--------wufan------ %s: Enter __axienet_device_reset\n", __func__);
 		__axienet_device_reset(q);
 	}
 
@@ -646,7 +656,7 @@ static int axienet_device_reset(struct net_device *ndev)
 		    lp->axienet_config->mactype != XAXIENET_MRMAC)
 			lp->options |= XAE_OPTION_JUMBO;
 	}
-
+	printk("--------wufan------ %s: Enter axienet_dma_bd_init\n", __func__);
 	ret = axienet_dma_bd_init(ndev);
 	if (ret < 0) {
 		netdev_err(ndev, "%s: descriptor allocation failed\n",
@@ -657,8 +667,10 @@ static int axienet_device_reset(struct net_device *ndev)
 	if (lp->axienet_config->mactype != XAXIENET_10G_25G &&
 	    lp->axienet_config->mactype != XAXIENET_1G_10G_25G &&
 	    lp->axienet_config->mactype != XAXIENET_MRMAC) {
+		printk("--------wufan------ %s: Enter axienet_ior(lp, XAE_RCW1_OFFSET)\n", __func__);
 		axienet_status = axienet_ior(lp, XAE_RCW1_OFFSET);
 		axienet_status &= ~XAE_RCW1_RX_MASK;
+		printk("--------wufan------ %s: Enter axienet_iow(lp, XAE_RCW1_OFFSET, axienet_status)\n", __func__);
 		axienet_iow(lp, XAE_RCW1_OFFSET, axienet_status);
 	}
 
@@ -674,15 +686,18 @@ static int axienet_device_reset(struct net_device *ndev)
 		minor = (lp->xxv_ip_version & XXV_MIN_MASK) >> 8;
 
 		if (maj == 3 ? minor >= 2 : maj > 3) {
+			printk("--------wufan------ %s: Enter readl_poll_timeout\n", __func__);
 			err = readl_poll_timeout(lp->regs + XXV_STAT_GTWIZ_OFFSET,
 						 val, (val & XXV_GTWIZ_RESET_DONE),
 						 10, DELAY_OF_ONE_MILLISEC);
 			if (err) {
 				netdev_err(ndev, "XXV MAC GT reset not complete! Cross-check the MAC ref clock configuration\n");
+				printk("--------wufan------ %s: Enter axienet_dma_bd_release\n", __func__);
 				axienet_dma_bd_release(ndev);
 				return err;
 			}
 		}
+		printk("--------wufan------ %s: Enter readl_poll_timeout\n", __func__);
 		err = readl_poll_timeout(lp->regs + XXV_STATRX_BLKLCK_OFFSET,
 					 val, (val & XXV_RX_BLKLCK_MASK),
 					 10, DELAY_OF_ONE_MILLISEC);
@@ -690,12 +705,16 @@ static int axienet_device_reset(struct net_device *ndev)
 			netdev_err(ndev, "XXV MAC block lock not complete! Cross-check the MAC ref clock configuration\n");
 
 #ifdef CONFIG_XILINX_AXI_EMAC_HWTSTAMP
+		printk("--------wufan------ %s: Enter axienet_rxts_iow(lp, XAXIFIFO_TXTS_RDFR,\n", __func__);
 		axienet_rxts_iow(lp, XAXIFIFO_TXTS_RDFR,
 				 XAXIFIFO_TXTS_RESET_MASK);
+		printk("--------wufan------ %s: Enter axienet_rxts_iow(lp, XAXIFIFO_TXTS_SRR,\n", __func__);
 		axienet_rxts_iow(lp, XAXIFIFO_TXTS_SRR,
 				 XAXIFIFO_TXTS_RESET_MASK);
+		printk("--------wufan------ %s: Enter axienet_txts_iow(lp, XAXIFIFO_TXTS_RDFR,\n", __func__);
 		axienet_txts_iow(lp, XAXIFIFO_TXTS_RDFR,
 				 XAXIFIFO_TXTS_RESET_MASK);
+		printk("--------wufan------ %s: Enter axienet_txts_iow(lp, XAXIFIFO_TXTS_SRR,\n", __func__);
 		axienet_txts_iow(lp, XAXIFIFO_TXTS_SRR,
 				 XAXIFIFO_TXTS_RESET_MASK);
 #endif
@@ -703,12 +722,16 @@ static int axienet_device_reset(struct net_device *ndev)
 
 #ifdef CONFIG_XILINX_AXI_EMAC_HWTSTAMP
 	if (lp->axienet_config->mactype == XAXIENET_MRMAC) {
+		printk("--------wufan------ %s: Enter axienet_rxts_iow(lp, XAXIFIFO_TXTS_RDFR,\n", __func__);
 		axienet_rxts_iow(lp, XAXIFIFO_TXTS_RDFR,
 				 XAXIFIFO_TXTS_RESET_MASK);
+		printk("--------wufan------ %s: Enter axienet_rxts_iow(lp, XAXIFIFO_TXTS_SRR,\n", __func__);
 		axienet_rxts_iow(lp, XAXIFIFO_TXTS_SRR,
 				 XAXIFIFO_TXTS_RESET_MASK);
+		printk("--------wufan------ %s: Enter axienet_txts_iow(lp, XAXIFIFO_TXTS_RDFR,\n", __func__);
 		axienet_txts_iow(lp, XAXIFIFO_TXTS_RDFR,
 				 XAXIFIFO_TXTS_RESET_MASK);
+		printk("--------wufan------ %s: Enter axienet_txts_iow(lp, XAXIFIFO_TXTS_SRR,\n", __func__);
 		axienet_txts_iow(lp, XAXIFIFO_TXTS_SRR,
 				 XAXIFIFO_TXTS_RESET_MASK);
 	}
@@ -716,10 +739,12 @@ static int axienet_device_reset(struct net_device *ndev)
 
 	if (lp->axienet_config->mactype == XAXIENET_1G &&
 	    !lp->eth_hasnobuf) {
+		printk("--------wufan------ %s: Enter axienet_ior(lp, XAE_IP_OFFSET);\n", __func__);
 		axienet_status = axienet_ior(lp, XAE_IP_OFFSET);
 		if (axienet_status & XAE_INT_RXRJECT_MASK)
 			axienet_iow(lp, XAE_IS_OFFSET, XAE_INT_RXRJECT_MASK);
 		/* Enable receive erros */
+		printk("--------wufan------ %s: Enter axienet_iow(lp, XAE_IE_OFFSET, lp->eth_irq > 0 ?\n", __func__);
 		axienet_iow(lp, XAE_IE_OFFSET, lp->eth_irq > 0 ?
 			    XAE_INT_RECV_ERROR_MASK : 0);
 	}
@@ -730,17 +755,22 @@ static int axienet_device_reset(struct net_device *ndev)
 		lp->options |= XAE_OPTION_FCS_STRIP;
 		lp->options |= XAE_OPTION_FCS_INSERT;
 	} else {
+		printk("--------wufan------ %s: Enter axienet_iow(lp, XAE_FCC_OFFSET, XAE_FCC_FCRX_MASK);\n", __func__);
 		axienet_iow(lp, XAE_FCC_OFFSET, XAE_FCC_FCRX_MASK);
 	}
+	printk("--------wufan------ %s: Enter setoptions\n", __func__);
 	lp->axienet_config->setoptions(ndev, lp->options &
 				       ~(XAE_OPTION_TXEN | XAE_OPTION_RXEN));
 
+	printk("--------wufan------ %s: Enter axienet_set_mac_address\n", __func__);
 	axienet_set_mac_address(ndev, NULL);
+	printk("--------wufan------ %s: Enter axienet_set_multicast_list\n", __func__);
 	axienet_set_multicast_list(ndev);
+	printk("--------wufan------ %s: Enter setoptions\n", __func__);
 	lp->axienet_config->setoptions(ndev, lp->options);
-
+	printk("--------wufan------ %s: Enter netif_trans_update\n", __func__);
 	netif_trans_update(ndev);
-
+	printk("--------wufan------ %s: Exit function\n", __func__);
 	return 0;
 }
 
@@ -1811,32 +1841,38 @@ static int axienet_open(struct net_device *ndev)
 	struct axienet_local *lp = netdev_priv(ndev);
 	struct axienet_dma_q *q;
 	u32 reg, err;
-
+	printk("--------wufan------ %s: Enter function\n", __func__);
 	dev_dbg(&ndev->dev, "axienet_open()\n");
 
 	/* When we do an Axi Ethernet reset, it resets the complete core
 	 * including the MDIO. MDIO must be disabled before resetting.
 	 * Hold MDIO bus lock to avoid MDIO accesses during the reset.
 	 */
+	printk("--------wufan------ %s: Enter axienet_lock_mii\n", __func__);
 	axienet_lock_mii(lp);
+	printk("--------wufan------ %s: Enter axienet_device_reset\n", __func__);
 	ret = axienet_device_reset(ndev);
+	printk("--------wufan------ %s: Enter axienet_unlock_mii\n", __func__);
 	axienet_unlock_mii(lp);
 	if (ret < 0) {
 		dev_err(lp->dev, "axienet_device_reset failed\n");
 		return ret;
 	}
-
+	printk("--------wufan------ %s: Enter lp->phylink\n", __func__);
 	if (lp->phylink) {
+		printk("--------wufan------ %s: Enter phylink_of_phy_connect\n", __func__);
 		ret = phylink_of_phy_connect(lp->phylink, lp->dev->of_node, 0);
 		if (ret) {
 			dev_err(lp->dev, "phylink_of_phy_connect() failed: %d\n", ret);
 			return ret;
 		}
 
+		printk("--------wufan------ %s: Enter phylink_start\n", __func__);
 		phylink_start(lp->phylink);
 	}
 
 	/* Enable tasklets for Axi DMA error handling */
+	printk("--------wufan------ %s: Enter for_each_rx_dma_queue\n", __func__);
 	for_each_rx_dma_queue(lp, i) {
 #ifdef CONFIG_AXIENET_HAS_MCDMA
 		tasklet_init(&lp->dma_err_tasklet[i],
@@ -1856,6 +1892,7 @@ static int axienet_open(struct net_device *ndev)
 		 */
 		napi_enable(&lp->napi[i]);
 	}
+	printk("--------wufan------ %s: Enter for_each_tx_dma_queue\n", __func__);
 	for_each_tx_dma_queue(lp, i) {
 		struct axienet_dma_q *q = lp->dq[i];
 #ifdef CONFIG_AXIENET_HAS_MCDMA
@@ -1872,7 +1909,7 @@ static int axienet_open(struct net_device *ndev)
 			goto err_tx_irq;
 #endif
 		}
-
+	printk("--------wufan------ %s: Enter for_each_rx_dma_queue\n", __func__);
 	for_each_rx_dma_queue(lp, i) {
 		struct axienet_dma_q *q = lp->dq[i];
 #ifdef CONFIG_AXIENET_HAS_MCDMA
@@ -1889,7 +1926,7 @@ static int axienet_open(struct net_device *ndev)
 			goto err_rx_irq;
 #endif
 	}
-
+	printk("--------wufan------ %s: Enter lp->phy_mode\n", __func__);
 	if (lp->phy_mode == PHY_INTERFACE_MODE_USXGMII) {
 		netdev_dbg(ndev, "RX reg: 0x%x\n",
 			   axienet_ior(lp, XXV_RCW1_OFFSET));
@@ -1961,7 +1998,7 @@ static int axienet_open(struct net_device *ndev)
 
 		netdev_info(ndev, "USXGMII setup at %d\n", lp->usxgmii_rate);
 	}
-
+	printk("--------wufan------ %s: Enter lp->axienet_config->mactype\n", __func__);
 	if (lp->axienet_config->mactype == XAXIENET_MRMAC) {
 		u32 val;
 
@@ -1998,7 +2035,7 @@ static int axienet_open(struct net_device *ndev)
 		netdev_info(ndev, "MRMAC setup at %d\n", lp->mrmac_rate);
 		axienet_iow(lp, MRMAC_TICK_OFFSET, MRMAC_TICK_TRIGGER);
 	}
-
+	printk("--------wufan------ %s: Enter lp->eth_hasnobuf\n", __func__);
 	/* Enable interrupts for Axi Ethernet core (if defined) */
 	if (!lp->eth_hasnobuf && lp->axienet_config->mactype == XAXIENET_1G) {
 		ret = request_irq(lp->eth_irq, axienet_eth_irq, IRQF_SHARED,
@@ -2006,14 +2043,14 @@ static int axienet_open(struct net_device *ndev)
 		if (ret)
 			goto err_eth_irq;
 	}
-
+	printk("--------wufan------ %s: Enter lp->axienet_config->mactype\n", __func__);
 	if (lp->axienet_config->mactype == XAXIENET_1G_10G_25G) {
 		axienet_config_autoneg_link_training(lp,
 						     (XXVS_AN_10G_ABILITY_MASK
 						     | XXVS_AN_1G_ABILITY_MASK));
 		schedule_delayed_work(&lp->restart_work, msecs_to_jiffies(500));
 	}
-
+	printk("--------wufan------ %s: Enter netif_tx_start_all_queues\n", __func__);
 	netif_tx_start_all_queues(ndev);
 	return 0;
 
@@ -2859,6 +2896,7 @@ static int __maybe_unused axienet_mcdma_probe(struct platform_device *pdev,
 	}
 
 	ret = of_property_read_u8(np, "xlnx,addrwidth", (u8 *)&lp->dma_mask);
+	dev_info(&pdev->dev, "get xlnx,addrwidth = %d, ret = %d, npname[%s], npfullname[%s]", lp->dma_mask, ret, np->name, np->full_name);
 	if (ret < 0 || lp->dma_mask < XAE_DMA_MASK_MIN ||
 	    lp->dma_mask > XAE_DMA_MASK_MAX) {
 		dev_info(&pdev->dev, "missing/invalid xlnx,addrwidth property, using default\n");
-- 
