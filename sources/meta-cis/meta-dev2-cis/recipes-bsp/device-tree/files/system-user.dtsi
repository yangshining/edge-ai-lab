#include <dt-bindings/interrupt-controller/irq.h>
/include/ "system-conf.dtsi"
/ {
	aliases {
		//spi0 = &#;
		spi1 = &spi0;
		spi2 = &spi1;
		spi3 = &axi_quad_spi_49a;
		spi4 = &axi_quad_spi_49b;
		spi5 = &axi_quad_spi_49c;
		spi6 = &axi_quad_spi_49d;
	};

	gpio_keys:@0 {
		compatible = "gpio-keys";
		label = "zulu Interrupt collection";

		gpio_irq0 {
			label = "EX_ALARM_B";
			gpios = <&gpio 68 1>;
			linux,code = <0x100>;
			debounce-interval = <20>;
		};

		gpio_irq1 {
			label = "EX_ALARM_A";
			gpios = <&gpio 69 1>;
			linux,code = <0x101>;
			debounce-interval = <20>;
		};
	};

};

&qspi {
	status = "okay";
	is-dual = <0>;
	num-cs = <1>;
	flash@0 {
		compatible ="jedec,spi-nor";
		reg = <0x0>;
		spi-tx-bus-width = <1>;
		spi-rx-bus-width = <4>;
		spi-max-frequency = <108000000>;
		#address-cells = <1>;
		#size-cells = <1>;
	};
};

&spi0 {
	status = "okay";
	num-cs = <1>;
	u-boot,dm-pre-reloc;
	phc@0 {
		compatible="idt,8a34000";
		reg = <0>;
		spi-max-frequency = <10000000>;
		reset-gpio = <&gpio 78 1>;//GPIO_ACTIVE_LOW
	};
};

&spi1 {
	status = "okay";
	num-cs = <1>;
	u-boot,dm-pre-reloc;
	spidev@0 {
		compatible="rohm,dh2228fv";
		reg = <0>;
		dbgname = "spi0-ff050000";
		spi-max-frequency = <5000000>;
	};
};

&sdhci0 {
	status = "okay";
	bus-width = <8>;
	non-removable;
	cap-mmc-highspeed;
	cap-sd-highspeed;
	disable-wp;
	no-1-8-v;
};

// &axi_intc_0 {
// 	status = "disabled";
// };

&watchdog0 {
	status = "okay";
	reset-on-timeout;
	timeout-sec = <60>;
};

&gem3 {
	status = "okay";
	phy-handle = <&phy0>;
	phy-mode = "sgmii";
	is-internal-pcspma = <0x1>;
	phy0: phy@1 {
		reg = <0x1>;
	};
};


&gem1 {
	status = "okay";
	phy-mode = "sgmii";
	is-internal-pcspma = <0x1>;

	fixed-link {
		speed = <1000>;
		full-duplex;
	};

	switch-link {
		reset-gpios = <&gpio 54 0>;
		fixed-ports = <0x8f>;
		phy-ports = <0x140>;
	};
};

