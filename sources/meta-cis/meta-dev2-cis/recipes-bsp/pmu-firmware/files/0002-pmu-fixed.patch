+   if (lane_active == 1)
+   {
+      Xil_Out32(SERDES_L1_BIST_CTRL_1, (Xil_In32(SERDES_L1_BIST_CTRL_1) & 0xFFFFFF1F));
+      Xil_Out32(SERDES_L1_BIST_FILLER_OUT, 0x1 );                       
