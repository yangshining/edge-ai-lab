+static int serdes_bist_static_settings(u32 lane_active) 
+{
+   if (lane_active == 0)
+   {
+      Xil_Out32(SERDES_L0_BIST_CTRL_1, (Xil_In32(SERDES_L0_BIST_CTRL_1) & 0xFFFFFF1F));
+      Xil_Out32(SERDES_L0_BIST_FILLER_OUT, 0x1 );                       
