+    * Power-up Request Status for PL
+    *  PSU_PMU_GLOBAL_REQ_PWRUP_STATUS_PL                          1
+    * (OFFSET, MASK, VALUE)      (0XFFD80110, 0x00800000U ,0x00000000U)
+		*/
+	mask_pollOnValue(PMU_GLOBAL_REQ_PWRUP_STATUS_OFFSET,
+		0x00800000U, 0x00000000U);
+
+/*##################################################################### */
+
+
+	return 1;
+}
