diff --git a/cmd/clu.c b/cmd/clu.c
new file mode 100644
index 0000000000..368959309a
--- /dev/null
+++ b/cmd/clu.c
@@ -0,0 +1,149 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * (C) Copyright 2020
+ * Zillnk Inc.
+ */
+#include <common.h>
+#include <command.h>
+#include <malloc.h>
+#include <bootm.h>
+#include <errno.h>
+#include <image.h>
+#include <nand.h>
+#include <asm/byteorder.h>
+#include <linux/ctype.h>
+#include <linux/err.h>
+#include <mapmem.h>
+#include <dm.h>
+#include <spi.h>
+#include <time.h>
+#include <timer.h>
+
+#define BUS			1
+#define CS			0
+#define MODE			0
+#define BITLEN			24
+#define READ			0
+#define WRITE			1
+
+#ifndef MAX_SPI_BYTES
+#	define MAX_SPI_BYTES 32	/* Maximum number of bytes we can handle */
+#endif
+
+
+static int do_spi_xfer(uchar *dout, uchar *din, int bitlen)
+{
+	struct spi_slave *slave;
+	int ret = 0;
+
+#ifdef CONFIG_DM_SPI
+	char name[30], *str;
+	struct udevice *dev;
+
+	snprintf(name, sizeof(name), "generic_%d:%d", BUS, CS);
+	str = strdup(name);
+	if (!str)
+		return -ENOMEM;
+	ret = spi_get_bus_and_cs(BUS, CS, &dev, &slave);
+	if (ret)
+		return ret;
+#else
+	slave = spi_setup_slave(BUS, CS, 1000000, MODE);
+	if (!slave) {
+		printf("Invalid device %d:%d\n", BUS, CS);
+		return -EINVAL;
+	}
+#endif
+
+	ret = spi_claim_bus(slave);
+	if (ret)
+		goto done;
+	ret = spi_xfer(slave, bitlen, dout, din,
+			SPI_XFER_BEGIN | SPI_XFER_END);
+#ifndef CONFIG_DM_SPI
+	/* We don't get an error code in this case */
+	if (ret)
+		ret = -EIO;
+#endif
+	if (ret) {
+		printf("Error %d during SPI transaction\n", ret);
+	}
+
+done:
+	spi_release_bus(slave);
+#ifndef CONFIG_DM_SPI
+	spi_free_slave(slave);
+#endif
+
+	return ret;
+}
+
+static int spi_rw(uint32_t addr, uchar value, uchar r_or_w)
+{
+	uint32_t sig = 0;
+	uchar *re_sig = (uchar *)&sig;
+	uchar din[MAX_SPI_BYTES];
+
+	if(r_or_w == READ){
+		printf("0x%08x=", addr);
+        *re_sig = 0x80 | ((0xffff & addr) >> 8);
+        *(re_sig + 1) = 0xff & (uchar)addr;
+	}
+	else{
+        *re_sig = (0xffff & addr) >> 8;
+        *(re_sig + 1) = 0xff & (uchar)addr;
+        *(re_sig + 2) = 0xff & value;
+	}
+
+	if(do_spi_xfer(re_sig, &din, BITLEN))
+	{
+		return 1;
+	}
+
+	if(r_or_w == READ){
+		printf("%02x\r\n", *(din + (BITLEN / 8 - 1)));
+	}
+	return 0;
+}
+
+static int do_clu_rw(struct cmd_tbl *cmdtp, int flag, int argc, char * const argv[])
+{
+	uchar r_or_w;
+
+	if(argc < 3)
+ show_usage:
+		return CMD_RET_USAGE;
+	if(!strcmp(argv[1], "r")){
+		r_or_w = READ;
+	}else if(!strcmp(argv[1], "w")){
+		r_or_w = WRITE;
+	}
+	else
+		goto show_usage;
+
+	size_t addr, value = 0;
+
+	addr = simple_strtol(argv[2], NULL, 16);
+
+	if(r_or_w == WRITE){
+		value = simple_strtoul(argv[3], NULL, 16);
+	}
+
+	if(addr > 0xffff || value > 0xff){
+		printf("clu:illegal address!\r\n");
+		goto show_usage;
+	}
+
+	return spi_rw(addr, value, r_or_w);
+
+}
+
+U_BOOT_CMD(
+	clu,	4,	0,	do_clu_rw,
+	"SPI utility command",
+	"[<addr>] [<r/w>] [<value>] - Boot kernel parameters\n"
+	"<R>       - Read operation\n"
+	"<W>       - write operations\n"
+	"<addr>    - The register address of the operation\n"
+	"<value>   - Hexadecimal string that gets sent"
+);
diff --git a/cmd/zboot.c b/cmd/zboot.c
new file mode 100644
index 0000000000..bc5a17d869
--- /dev/null
+++ b/cmd/zboot.c
@@ -0,0 +1,449 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * (C) Copyright 2020
+ * Ma Chun <chun.ma@zillnk.com>, Zillnk Inc.
+ */
+#include "zboot.h"
+
+static int do_spi_xfer(uchar *dout, uchar *din, int bitlen)
+{
+	struct spi_slave *slave;
+	int ret = 0;
+
+#ifdef CONFIG_DM_SPI
+	char name[30], *str;
+	struct udevice *dev;
+
+	snprintf(name, sizeof(name), "generic_%d:%d", BUS, CS);
+	str = strdup(name);
+	if (!str)
+		return -ENOMEM;
+	ret = spi_get_bus_and_cs(BUS, CS, &dev, &slave);
+	if (ret)
+		return ret;
+#else
+	slave = spi_setup_slave(BUS, CS, 1000000, MODE);
+	if (!slave) {
+		printf("Invalid device %d:%d\n", BUS, CS);
+		return -EINVAL;
+	}
+#endif
+
+	ret = spi_claim_bus(slave);
+	if (ret)
+		goto done;
+	ret = spi_xfer(slave, bitlen, dout, din,
+			SPI_XFER_BEGIN | SPI_XFER_END);
+#ifndef CONFIG_DM_SPI
+	/* We don't get an error code in this case */
+	if (ret)
+		ret = -EIO;
+#endif
+	if (ret) {
+		printf("Error %d during SPI transaction\n", ret);
+	}
+
+done:
+	spi_release_bus(slave);
+#ifndef CONFIG_DM_SPI
+	spi_free_slave(slave);
+#endif
+
+	return ret;
+}
+
+static int spi_read(uint32_t addr, uint16_t *value)
+{
+	uint32_t sig = 0;
+	uchar *re_sig = (uchar *)&sig;
+	uchar din[MAX_SPI_BYTES];
+
+	re_sig[0] = 0x80 | ((0xffff & addr) >> 8);
+	re_sig[1] = 0xff & (uchar)addr;
+
+	do_spi_xfer(re_sig, &din, BITLEN);
+	*value = *(din + (BITLEN / 8 - 1));
+	return 0;
+}
+
+static int spi_write(uchar *dout)
+{
+	uchar din[MAX_SPI_BYTES];
+	return do_spi_xfer(dout, &din, BITLEN);
+}
+
+static int clu_init()
+{
+	int i, ret;
+	uint8_t value = 0;
+
+	for(i = 0; i < (sizeof(reg_data) / sizeof(reg_data[0])); i++){
+		spi_write(&reg_data[i]);
+		udelay(5000);
+	}
+
+	udelay(500000);
+
+	/* check SYCCLK and PLL status*/
+	ret = spi_read(0x3001, &value);
+	if (ret) {
+		printf("read reg[0x3001] faild %d\n", ret);
+		return ret;
+	}
+
+	if ((value & SYSCLK_PLL_MASK) != SYSCLK_PLL_OK) {
+		printf("SYSCLK PLL status [0x%x]not OK\n", value);
+		return 1;
+	}
+
+	spi_write("\x21\x00\x00");
+	spi_write("\x00\x0F\x01");
+	spi_write("\x21\x00\x02");
+	spi_write("\x00\x0F\x01");
+
+	udelay(500000);
+
+	/* check PLL0 status*/
+	value = 0;
+	ret = spi_read(0x3100, &value);
+	if (ret) {
+		printf("read reg[0x3100] faild %d\n", ret);
+		return ret;
+	}
+
+	if ((value & PLL0_LOCK_MASK) != PLL0_LOCK_OK) {
+		printf("PLL0 Lock status [0x%x]not OK\n", value);
+		return 1;
+	}
+
+	spi_write("\x22\x00\x00");
+	spi_write("\x00\x0F\x01");
+	spi_write("\x22\x00\x02");
+	spi_write("\x00\x0F\x01");
+
+	udelay(500000);
+
+	/* check PLL1 status*/
+	value = 0;
+	ret = spi_read(0x3200, &value);
+	if (ret) {
+		printf("read reg[0x3200] faild %d\n", ret);
+		return ret;
+	}
+
+	if ((value & PLL1_LOCK_MASK) != PLL1_LOCK_OK) {
+		printf("PLL1 Lock status [0x%x]not OK\n", value);
+		return 1;
+	}
+
+	spi_write("\x02\x84\x02");
+	spi_write("\x00\x0F\x01");
+
+	printf("CLU OK!\n");
+	return 0;
+
+}
+
+static long get_fpga_device(char *arg)
+{
+	long dev = FPGA_INVALID_DEVICE;
+	char *devstr = env_get("fpga");
+
+	if (devstr)
+		/* Should be strtol to handle -1 cases */
+		dev = simple_strtol(devstr, NULL, 16);
+
+	if (dev == FPGA_INVALID_DEVICE && arg)
+		dev = simple_strtol(arg, NULL, 16);
+
+	printf("%s: device = %ld\n", __func__, dev);
+
+	return dev;
+}
+
+static int do_fpga_loadb(uint32_t fpgadata, uint32_t datasize)
+{
+	long dev;
+
+	/* use device zero */
+	dev = get_fpga_device("0");
+	if (dev < 0) {
+		printf("ERROR git fpga device failed!\n");
+		return -1;
+	}
+
+	return fpga_loadbitstream(dev, (void *)fpgadata, datasize, BIT_FULL);
+}
+
+static int parse_head_data(uint32_t base_addr)
+{
+	struct head head_data;
+	uint8_t *dataptr;
+	int ret = 0;
+	char cmd[64];
+
+	dataptr = (uint8_t*)base_addr;
+	head_data.identifier = *((uint32_t *)dataptr);
+
+	dataptr += sizeof(head_data.identifier);
+	head_data.reserve_size = *((uint8_t *)dataptr);
+	head_data.reserve = dataptr;
+
+	dataptr += head_data.reserve_size;
+	LEGAL_ADDR(base_addr, dataptr);
+	head_data.crc32 = *((uint32_t *)dataptr);
+
+	dataptr += sizeof(head_data.crc32);
+	head_data.blob_size = *((uint32_t *)dataptr);
+
+	dataptr += sizeof(head_data.blob_size);
+	head_data.reserve2_size = *((uint8_t *)dataptr);
+	head_data.reserve2 = dataptr;
+
+	dataptr += head_data.reserve2_size;
+	LEGAL_ADDR(base_addr, dataptr);
+	head_data.reserve3_size = *((uint8_t *)dataptr);
+	head_data.reserve3 = dataptr;
+
+	dataptr += head_data.reserve3_size;
+	LEGAL_ADDR(base_addr, dataptr);
+	head_data.info_start[0] = *((uint8_t *)dataptr);
+	head_data.info_start[1] = *((uint8_t *)(dataptr + 1));
+
+	dataptr += sizeof(head_data.info_start);
+	head_data.info_size = *((uint8_t *)dataptr);
+	head_data.info = dataptr + 1;
+
+	dataptr += head_data.info_size + 1;
+	LEGAL_ADDR(base_addr, dataptr);
+	head_data.vers_start[0] = *((uint8_t *)dataptr);
+	head_data.vers_start[1] = *((uint8_t *)(dataptr + 1));
+
+	dataptr += sizeof(head_data.vers_start);
+	head_data.version_size = *((uint8_t *)dataptr);
+	head_data.version = dataptr + 1;
+
+	dataptr += head_data.version_size + 2;
+	LEGAL_ADDR(base_addr, dataptr);
+	head_data.bit_offset = *((uint32_t *)dataptr);
+	head_data.kernel_offset = *((uint32_t *)dataptr + 1);
+	head_data.bit_size = *((uint32_t *)dataptr + 2);
+	head_data.head_size = *((uint32_t *)dataptr + 3);
+	head_data.zboot_offset = *((uint32_t *)dataptr + 4);
+	head_data.mbr_offset = *((uint32_t *)dataptr + 5);
+
+	uint8_t mask = *((uint8_t *)(head_data.reserve3 + 1));
+
+#if 0
+	printf("%s: identifier : %#x\n", __func__, head_data.identifier);
+	printf("%s: reserve_size : %d\t reserve: %d\n", __func__, head_data.reserve_size, head_data.reserve);
+	printf("%s: crc32 : %#x\t blob_size: %#x\n", __func__, head_data.crc32, head_data.blob_size);
+	printf("%s: reserve2_size : %#x\t reserve2: %d\n", __func__, head_data.reserve2_size, *((uint32_t *)head_data.reserve2));
+	printf("%s: reserve3_size : %#x\t reserve3: %d\t mask: %#x\n", __func__, head_data.reserve3_size, head_data.reserve3, mask);
+	printf("%s: info_start[0] : %#x\t info_start[1]: %#x\n", __func__, head_data.info_start[0], head_data.info_start[1]);
+	printf("%s: info_size : %#x\t info: %s\n", __func__, head_data.info_size, head_data.info);
+	printf("%s: vers_start[0] : %#x\t vers_start[1]: %x\n", __func__, head_data.vers_start[0], head_data.vers_start[1]);
+	printf("%s: version_size : %#x\t version: %s\n", __func__, head_data.version_size, head_data.version);
+	printf("%s: bit_offset : %#x\t kernel_offset: %#x\t bit_size: %#x\n", __func__, head_data.bit_offset, head_data.kernel_offset, head_data.bit_size);
+	printf("%s: head_size: %#x\t zboot_offset: %#x\t mbr_offset: %#x\n", __func__, head_data.head_size, head_data.zboot_offset, head_data.mbr_offset);
+#endif
+
+	if (mask & 0x2)
+	{
+		uint32_t zboot_date = 0;
+		if (mask & 0x1)
+			zboot_date = (*(uint32_t *)(head_data.reserve3 + *(uint8_t *)(head_data.reserve3 + 2) + 3));
+		else
+			zboot_date = (*(uint32_t *)(head_data.reserve3 + 2));
+
+		zboot_date = (zboot_date >> 8) & 0xffffff;
+		if (zboot_date > ZBOOT_DATE)
+			printf("zboot %d -> %d!\n", ZBOOT_DATE, zboot_date);
+		else
+			return 0;
+		uint32_t zboot_size = head_data.bit_offset - head_data.zboot_offset;
+		//sf probe 0 0 0 && sf erase 0x0 0x1c0000 && sf write 0x8000000 0x0 ${filesize}
+		ret |= run_command("sf probe 0 0 0", 0);
+		ret |= run_command("sf erase 0x0 0x1c0000", 0);
+		if (ret)
+			return -1;
+
+		snprintf(cmd, sizeof(cmd), "sf write %#x 0x0 %#x", base_addr + head_data.head_size + head_data.zboot_offset, zboot_size);
+		printf("cmd : %s\n", cmd);
+		ret |= run_command(cmd, 0);
+		if (ret)
+			return -1;
+		run_command("reset", 0);
+	}
+}
+
+static int to_bootm(uint32_t image_addr)
+{
+	int ret = 0;
+	char *bootm_argv[2];
+	char boot_addr[16];
+	/* create paramter array */
+	bootm_argv[0] = "bootm";
+	bootm_argv[1] = boot_addr;
+
+
+	snprintf(boot_addr, sizeof(boot_addr), "0x%lx", image_addr);
+
+	ret = do_bootm(find_cmd("do_bootm"), 0, 2,
+			bootm_argv);
+
+	if (ret) {
+		printf("ERROR prep subcommand failed!\n");
+		return -1;
+	}
+	return 0;
+}
+
+static int do_zboot(struct cmd_tbl *cmdtp, int flag, int argc, char * const argv[])
+{
+	slot_head *sh;
+	uint32_t base_addr, image_addr, fpga_data_addr, unzip_data_addr, local_data_size;
+	uint32_t fpga_data_size = 0, unzip_data_size = ~0UL;
+	uint32_t *checksum, *crc_len;
+	uint8_t *dataptr, *crc_data;
+	uint8_t length;
+
+	base_addr = simple_strtol(argv[1], NULL, 16);
+	if (!base_addr) {
+		printf("%s: zero zboot_data address\n", __func__);
+		return CMD_RET_USAGE;
+	}
+
+	local_data_size = simple_strtoul(argv[2], NULL, 16);
+	if (!local_data_size) {
+		printf("%s: zero size\n", __func__);
+		return CMD_RET_USAGE;
+	}
+
+	if (*((uint32_t *)base_addr) != FILE_HEAD) {
+		printf("%s: unrecognized file type!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	dataptr = (uint8_t*)base_addr;
+	length = (*dataptr << 8) + *(dataptr + 4);
+	dataptr += length;
+	dataptr += 4;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	checksum = (uint32_t *)(dataptr);
+	crc_data = (uint8_t *)(dataptr);
+	dataptr += 4;
+
+	crc_len = (uint32_t *)(dataptr);
+	dataptr += 4;
+
+	if (*((uint32_t *)dataptr) > local_data_size) {
+		printf("%s: CRC parameter error!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	crc_data = crc_data + *((uint32_t *)(dataptr));
+
+	if (*checksum != crc32(0, crc_data, *crc_len)){
+		printf("%s: CRC check error!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	parse_head_data(base_addr);
+
+	/* skip the first bytes, their meaning is unknown */
+	length = (*dataptr << 8) + *(dataptr + 4);
+	dataptr += 4;
+	dataptr += length;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	if (*dataptr++ != 0x5A) {
+		printf("%s: Design data id not recognized\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	length = (*dataptr << 8) + *(dataptr + 1);
+	dataptr += 2;
+
+	printf("  version information = \"%s\"\n", dataptr);
+	dataptr += length;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	/* get part version */
+	if (*dataptr++ != 0X4C) {
+		printf("%s: Part version id not recognized\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	length = (*dataptr << 8) + *(dataptr + 1);
+	dataptr += 2;
+	printf("  version = %s\n", dataptr);
+
+	dataptr += length;
+	dataptr++;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	sh = (slot_head *)dataptr;
+
+	fpga_data_addr = base_addr + sh->bit_offset + sh->head_size;
+	fpga_data_size = sh->bit_size;
+
+	/* Reserved 10M, */
+	unzip_data_addr = fpga_data_addr + fpga_data_size + SZ_10M;
+
+	/* 8 byte align */
+	BYTES_ALIGN(unzip_data_addr);
+
+	/**
+	 * gunzip() - Decompress gzipped data
+	 *
+	 * @dst: Destination for uncompressed data
+	 * @dstlen: Size of destination buffer
+	 * @src: Source data to decompress
+	 * @lenp: Returns length of uncompressed data
+	 * @return 0 if OK, -1 on error
+	 */
+	if (gunzip((void *)unzip_data_addr, ~0UL, (void *)fpga_data_addr, &unzip_data_size) != 0) {
+		printf("%s: Failure to decompress!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	/* load fpga */
+	if(0 != do_fpga_loadb(unzip_data_addr, unzip_data_size))
+	{
+		printf("%s: FPGA configuration error!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+#ifdef CONFIG_CLU_INIT
+	printf("CLU config...\r\n");
+	clu_init();
+#endif
+
+	image_addr = base_addr + sh->head_size + sh->kernel_offset;
+
+	env_set("zboot_ver", ZBOOT_VERSION);
+	env_set("zboot_info", ZBOOT_INFO);
+	env_save();
+	/* boot kernel */
+
+	to_bootm(image_addr);
+
+	return 0;
+}
+
+U_BOOT_CMD(
+	zboot,	3,	0,	do_zboot,
+	"zboot starts the system",
+	"[<addr>] [<size> <CRU>] - Boot kernel parameters\n"
+	"<addr>     - memory address of the boot\n"
+	"<size>     - Size of mirror image\n"
+	"Version: " ZBOOT_VERSION "\n"
+	"Info: " ZBOOT_INFO "\n"
+);
+
diff --git a/cmd/zboot.h b/cmd/zboot.h
new file mode 100644
index 0000000000..213d4a8945
--- /dev/null
+++ b/cmd/zboot.h
@@ -0,0 +1,368 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * (C) Copyright 2020
+ * Zillnk Inc.
+ */
+
+#ifndef __ZBOOT_H
+#define __ZBOOT_H
+
+
