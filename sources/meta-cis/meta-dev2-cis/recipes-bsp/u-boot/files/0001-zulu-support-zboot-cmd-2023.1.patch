+static int do_sftest(struct cmd_tbl *cmdtp, int flag, int argc,
+			char * const argv[])
+{
+	ulong offset, start;
+	ulong limits, len;
+	char *endp;
+	u8 *buf, *from;
+	u8 *vbuf;
+	int ret;
+	int i;
+
+	if (argc < 2)
+		return -1;
+
+	start = simple_strtoul(argv[1], &endp, 16);
+	if (*argv[1] == 0 || *endp != 0)
+		return -1;
+	
+	len = simple_strtoul(argv[2], &endp, 16);
+	if (*argv[2] == 0 || *endp != 0)
+		return -1;
+
+	limits = simple_strtoul(argv[3], &endp, 16);
+	if (*argv[3] == 0 || *endp != 0)
+		return -1;
+
+	vbuf = memalign(ARCH_DMA_MINALIGN, len);
+	if (!vbuf) {
+		printf("Cannot allocate memory (%lu bytes)\n", len);
+		return 1;
+	}
+
+	buf = memalign(ARCH_DMA_MINALIGN, len);
+	if (!buf) {
+		free(vbuf);
+		printf("Cannot allocate memory (%lu bytes)\n", len);
+		return 1;
+	}
+
+	from = map_sysmem(CONFIG_TEXT_BASE, 0);
+	memcpy(buf, from, len);
+
+	printf("Testing %08lx to %08lx:\n", start, flash->size);
+
+	for (i=0; i<limits; i++) {
+		for (offset = start; offset < flash->size - len; offset += len) {
+			//printf("Testing %08lx ... %08lx:\r", offset, offset + len);
+
+			ret = spi_flash_test(flash, buf, len, offset, vbuf);
+			if (ret) {
+					goto err;
+			}
+		}
+	}
+
+err:
+	printf("\n");
+	printf("Tested %d time(s), Test %s .\n", i, ret ? "failed" : "passed");
+	free(vbuf);
+	free(buf);
+	return ret;
+}
+
+U_BOOT_CMD(
+	sftest,	4,	1,	do_sftest,
+	"spi flash read/write test",
+	"offset  len  limits"
+);
diff --git a/cmd/zboot.c b/cmd/zboot.c
new file mode 100644
index 0000000000..0bbfe9234c
--- /dev/null
+++ b/cmd/zboot.c
@@ -0,0 +1,381 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * (C) Copyright 2020
+ * Ma Chun <chun.ma@zillnk.com>, Zillnk Inc.
+ */
+#include "zboot.h"
+
+static int do_spi_xfer(uchar *dout, uchar *din, int bitlen)
+{
+	struct spi_slave *slave;
+	int ret = 0;
+
+#ifdef CONFIG_DM_SPI
+	char name[30], *str;
+	struct udevice *dev;
+
+	snprintf(name, sizeof(name), "generic_%d:%d", BUS, CS);
+	str = strdup(name);
+	if (!str)
+		return -ENOMEM;
+	ret = spi_get_bus_and_cs(BUS, CS, 1000000, MODE, "spi_generic_drv",
+				 str, &dev, &slave);
+	if (ret)
+		return ret;
+#else
+	slave = spi_setup_slave(BUS, CS, 1000000, MODE);
+	if (!slave) {
+		printf("Invalid device %d:%d\n", BUS, CS);
+		return -EINVAL;
+	}
+#endif
+
+	ret = spi_claim_bus(slave);
+	if (ret)
+		goto done;
+	ret = spi_xfer(slave, bitlen, dout, din,
+			SPI_XFER_BEGIN | SPI_XFER_END);
+#ifndef CONFIG_DM_SPI
+	/* We don't get an error code in this case */
+	if (ret)
+		ret = -EIO;
+#endif
+	if (ret) {
+		printf("Error %d during SPI transaction\n", ret);
+	}
+
+done:
+	spi_release_bus(slave);
+#ifndef CONFIG_DM_SPI
+	spi_free_slave(slave);
+#endif
+
+	return ret;
+}
+
+static int spi_read(uint32_t addr, uint16_t *value)
+{
+	uint32_t sig = 0;
+	uchar *re_sig = (uchar *)&sig;
+	uchar din[MAX_SPI_BYTES];
+
+	re_sig[0] = 0x80 | ((0xffff & addr) >> 8);
+	re_sig[1] = 0xff & (uchar)addr;
+
+	do_spi_xfer(re_sig, &din, BITLEN);
+	*value = *(din + (BITLEN / 8 - 1));
+	return 0;
+}
+
+static int spi_write(uchar *dout)
+{
+	uchar din[MAX_SPI_BYTES];
+	return do_spi_xfer(dout, &din, BITLEN);
+}
+
+static int clu_init()
+{
+	int i, ret;
+	uint8_t value = 0;
+
+	for(i = 0; i < (sizeof(reg_data) / sizeof(reg_data[0])); i++){
+		spi_write(&reg_data[i]);
+		udelay(5000);
+	}
+
+	udelay(500000);
+
+	/* check SYCCLK and PLL status*/
+	ret = spi_read(0x3001, &value);
+	if (ret) {
+		printf("read reg[0x3001] faild %d\n", ret);
+		return ret;
+	}
+
+	if ((value & SYSCLK_PLL_MASK) != SYSCLK_PLL_OK) {
+		printf("SYSCLK PLL status [0x%x]not OK\n", value);
+		return 1;
+	}
+
+	spi_write("\x21\x00\x00");
+	spi_write("\x00\x0F\x01");
+	spi_write("\x21\x00\x02");
+	spi_write("\x00\x0F\x01");
+
+	udelay(500000);
+
+	/* check PLL0 status*/
+	value = 0;
+	ret = spi_read(0x3100, &value);
+	if (ret) {
+		printf("read reg[0x3100] faild %d\n", ret);
+		return ret;
+	}
+
+	if ((value & PLL0_LOCK_MASK) != PLL0_LOCK_OK) {
+		printf("PLL0 Lock status [0x%x]not OK\n", value);
+		return 1;
+	}
+
+	spi_write("\x22\x00\x00");
+	spi_write("\x00\x0F\x01");
+	spi_write("\x22\x00\x02");
+	spi_write("\x00\x0F\x01");
+
+	udelay(500000);
+
+	/* check PLL1 status*/
+	value = 0;
+	ret = spi_read(0x3200, &value);
+	if (ret) {
+		printf("read reg[0x3200] faild %d\n", ret);
+		return ret;
+	}
+
+	if ((value & PLL1_LOCK_MASK) != PLL1_LOCK_OK) {
+		printf("PLL1 Lock status [0x%x]not OK\n", value);
+		return 1;
+	}
+
+	spi_write("\x02\x84\x02");
+	spi_write("\x00\x0F\x01");
+
+	printf("CLU OK!\n");
+	return 0;
+
+}
+
+static long get_fpga_device(char *arg)
+{
+	long dev = FPGA_INVALID_DEVICE;
+	char *devstr = env_get("fpga");
+
+	if (devstr)
+		/* Should be strtol to handle -1 cases */
+		dev = simple_strtol(devstr, NULL, 16);
+
+	if (dev == FPGA_INVALID_DEVICE && arg)
+		dev = simple_strtol(arg, NULL, 16);
+
+	printf("%s: device = %ld\n", __func__, dev);
+
+	return dev;
+}
+
+static int do_fpga_loads_rsa_bitstream(int devnum, uint32_t fpga_data, uint32_t data_size)
+{
+	struct fpga_secure_info fpga_sec_info;
+	
+	memset(&fpga_sec_info, 0, sizeof(fpga_sec_info));
+	/*
+	*	auth_loc :
+	*
+	*	location of image to be authenticated is located
+	*
+	*	0 = On-Chip Memory (OCM)
+	*
+	*	1 = DDR
+	*
+	*	2 = no authentication
+	*/
+	fpga_sec_info.authflag = 1; //DDR
+	/*
+	* enc_key_sel :
+	*
+	* selection of the encryption key
+	*
+	* 0 = device key
+	*
+	* 1 = user key - KUP
+	*
+	* 2 = no encryption
+	*/
+	fpga_sec_info.encflag = 2;
+	printf("fpga load rsa bitstream.\n");
+	return fpga_loads(devnum, (void *)fpga_data, data_size, &fpga_sec_info);
+}
+
+static int do_fpga_loadb(uint32_t fpgadata, uint32_t datasize)
+{
+	long dev;
+
+	/* use device zero */
+	dev = get_fpga_device("0");
+	if (dev < 0) {
+		printf("ERROR git fpga device failed!\n");
+		return -1;
+	}
+#ifdef CONFIG_ZBOOT_RSA_BITSTREAM
+	return do_fpga_loads_rsa_bitstream(dev, fpgadata, datasize);
+#else
+	return fpga_loadbitstream(dev, (void *)fpgadata, datasize, BIT_FULL);
+#endif
+}
+
+static int to_bootm(uint32_t image_addr)
+{
+	int ret = 0;
+	char *bootm_argv[2];
+	char boot_addr[16];
+	/* create paramter array */
+	bootm_argv[0] = "bootm";
+	bootm_argv[1] = boot_addr;
+
+
+	snprintf(boot_addr, sizeof(boot_addr), "0x%lx", image_addr);
+
+	ret = do_bootm(find_cmd("do_bootm"), 0, 2,
+			bootm_argv);
+
+	if (ret) {
+		printf("ERROR prep subcommand failed!\n");
+		return -1;
+	}
+	return 0;
+}
+
+static int do_zboot(struct cmd_tbl *cmdtp, int flag, int argc, char * const argv[])
+{
+	slot_head *sh;
+	uint32_t base_addr, image_addr, fpga_data_addr, unzip_data_addr, local_data_size;
+	uint32_t fpga_data_size = 0, unzip_data_size = ~0UL;
+	uint32_t *checksum, *crc_len;
+	uint8_t *dataptr, *crc_data;
+	uint8_t length;
+
+	base_addr = simple_strtol(argv[1], NULL, 16);
+	if (!base_addr) {
+		printf("%s: zero zboot_data address\n", __func__);
+		return CMD_RET_USAGE;
+	}
+
+	local_data_size = simple_strtoul(argv[2], NULL, 16);
+	if (!local_data_size) {
+		printf("%s: zero size\n", __func__);
+		return CMD_RET_USAGE;
+	}
+
+	if (*((uint32_t *)base_addr) != FILE_HEAD) {
+		printf("%s: unrecognized file type!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	dataptr = (uint8_t*)base_addr;
+	length = (*dataptr << 8) + *(dataptr + 4);
+	dataptr += length;
+	dataptr += 4;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	checksum = (uint32_t *)(dataptr);
+	crc_data = (uint8_t *)(dataptr);
+	dataptr += 4;
+
+	crc_len = (uint32_t *)(dataptr);
+	dataptr += 4;
+
+	if (*((uint32_t *)dataptr) > local_data_size) {
+		printf("%s: CRC parameter error!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	crc_data = crc_data + *((uint32_t *)(dataptr));
+
+	if (*checksum != crc32(0, crc_data, *crc_len)){
+		printf("%s: CRC check error!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	/* skip the first bytes, their meaning is unknown */
+	length = (*dataptr << 8) + *(dataptr + 4);
+	dataptr += 4;
+	dataptr += length;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	if (*dataptr++ != 0x5A) {
+		printf("%s: Design data id not recognized\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	length = (*dataptr << 8) + *(dataptr + 1);
+	dataptr += 2;
+
+	printf("  version information = \"%s\"\n", dataptr);
+	dataptr += length;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	/* get part version */
+	if (*dataptr++ != 0X4C) {
+		printf("%s: Part version id not recognized\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	length = (*dataptr << 8) + *(dataptr + 1);
+	dataptr += 2;
+	printf("  version = %s\n", dataptr);
+
+	dataptr += length;
+	dataptr++;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	sh = (slot_head *)dataptr;
+
+	fpga_data_addr = base_addr + sh->bit_offset + sh->head_size;
+	fpga_data_size = sh->bit_size;
+
+	/* Reserved 10M, */
+	unzip_data_addr = fpga_data_addr + fpga_data_size + SZ_10M;
+
+	/* 8 byte align */
+	BYTES_ALIGN(unzip_data_addr);
+
+	/**
+	 * gunzip() - Decompress gzipped data
+	 *
+	 * @dst: Destination for uncompressed data
+	 * @dstlen: Size of destination buffer
+	 * @src: Source data to decompress
+	 * @lenp: Returns length of uncompressed data
+	 * @return 0 if OK, -1 on error
+	 */
+	if (gunzip((void *)unzip_data_addr, ~0UL, (void *)fpga_data_addr, &unzip_data_size) != 0) {
+		printf("%s: Failure to decompress!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	/* load fpga */
+	if(0 != do_fpga_loadb(unzip_data_addr, unzip_data_size))
+	{
+		printf("%s: FPGA configuration error!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+#ifdef CONFIG_CLU_INIT
+	printf("CLU config...\r\n");
+	clu_init();
+#endif
+
+	image_addr = base_addr + sh->head_size + sh->kernel_offset;
+
+	env_set("zboot_ver", ZBOOT_VERSION);
+	env_set("zboot_info", ZBOOT_INFO);
+	env_save();
+	/* boot kernel */
+
+	to_bootm(image_addr);
+
+	return 0;
+}
+
+U_BOOT_CMD(
+	zboot,	3,	0,	do_zboot,
+	"zboot starts the system",
+	"[<addr>] [<size> <CRU>] - Boot kernel parameters\n"
+	"<addr>     - memory address of the boot\n"
+	"<size>     - Size of mirror image\n"
+	"Version: " ZBOOT_VERSION "\n"
+	"Info: " ZBOOT_INFO "\n"
+);
