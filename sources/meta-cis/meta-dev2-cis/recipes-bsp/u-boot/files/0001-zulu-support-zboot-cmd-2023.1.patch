new file mode 100644
index 0000000000..9f1b83af9f
--- /dev/null
+++ b/cmd/clu.c
@@ -0,0 +1,149 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * (C) Copyright 2020
+ * Zillnk Inc.
+ */
+#include <common.h>
+#include <command.h>
+#include <malloc.h>
+#include <bootm.h>
+#include <errno.h>
+#include <image.h>
+#include <nand.h>
+#include <asm/byteorder.h>
+#include <linux/ctype.h>
+#include <linux/err.h>
+#include <mapmem.h>
+#include <dm.h>
+#include <spi.h>
+#include <time.h>
+#include <timer.h>
+
+#define BUS			1
+#define CS			0
+#define MODE			0
+#define BITLEN			24
+#define READ			0
+#define WRITE			1
+
+#ifndef MAX_SPI_BYTES
+#	define MAX_SPI_BYTES 32	/* Maximum number of bytes we can handle */
+#endif
+
+
+static int do_spi_xfer(uchar *dout, uchar *din, int bitlen)
+{
+	struct spi_slave *slave;
+	int ret = 0;
+
+#ifdef CONFIG_DM_SPI
+	char name[30], *str;
+	struct udevice *dev;
+
+	snprintf(name, sizeof(name), "generic_%d:%d", BUS, CS);
+	str = strdup(name);
+	if (!str)
+		return -ENOMEM;
+	ret = spi_get_bus_and_cs(BUS, CS, &dev, &slave);
+	if (ret)
+		return ret;
+#else
+	slave = spi_setup_slave(BUS, CS, 1000000, MODE);
+	if (!slave) {
+		printf("Invalid device %d:%d\n", BUS, CS);
+		return -EINVAL;
+	}
+#endif
+
+	ret = spi_claim_bus(slave);
+	if (ret)
+		goto done;
+	ret = spi_xfer(slave, bitlen, dout, din,
+			SPI_XFER_BEGIN | SPI_XFER_END);
+#ifndef CONFIG_DM_SPI
+	/* We don't get an error code in this case */
+	if (ret)
+		ret = -EIO;
+#endif
+	if (ret) {
+		printf("Error %d during SPI transaction\n", ret);
+	}
+
+done:
+	spi_release_bus(slave);
+#ifndef CONFIG_DM_SPI
+	spi_free_slave(slave);
+#endif
+
+	return ret;
+}
+
+static int spi_rw(uint32_t addr, uchar value, uchar r_or_w)
+{
+	uint32_t sig = 0;
+	uchar *re_sig = (uchar *)&sig;
+	uchar din[MAX_SPI_BYTES];
+
+	if(r_or_w == READ){
+		printf("0x%08x=", addr);
+        *re_sig = 0x80 | ((0xffff & addr) >> 8);
+        *(re_sig + 1) = 0xff & (uchar)addr;
+	}
+	else{
+        *re_sig = (0xffff & addr) >> 8;
+        *(re_sig + 1) = 0xff & (uchar)addr;
+        *(re_sig + 2) = 0xff & value;
+	}
+
+	if(do_spi_xfer(re_sig, &din, BITLEN))
+	{
+		return 1;
+	}
+
+	if(r_or_w == READ){
+		printf("%02x\r\n", *(din + (BITLEN / 8 - 1)));
+	}
+	return 0;
+}
+
+static int do_clu_rw(struct cmd_tbl *cmdtp, int flag, int argc, char * const argv[])
+{
+	uchar r_or_w;
+
+	if(argc < 3)
+ show_usage:
+		return CMD_RET_USAGE;
+	if(!strcmp(argv[1], "r")){
+		r_or_w = READ;
+	}else if(!strcmp(argv[1], "w")){
+		r_or_w = WRITE;
+	}
+	else
+		goto show_usage;
+
+	size_t addr, value = 0;
+
+	addr = simple_strtol(argv[2], NULL, 16);
+
+	if(r_or_w == WRITE){
+		value = simple_strtoul(argv[3], NULL, 16);
+	}
+
+	if(addr > 0xffff || value > 0xff){
+		printf("clu:illegal address!\r\n");
+		goto show_usage;
+	}
+
+	return spi_rw(addr, value, r_or_w);
+
+}
+
+U_BOOT_CMD(
+	clu,	4,	0,	do_clu_rw,
+	"SPI utility command",
+	"[<addr>] [<r/w>] [<value>] - Boot kernel parameters\n"
+	"<R>       - Read operation\n"
+	"<W>       - write operations\n"
+	"<addr>    - The register address of the operation\n"
+	"<value>   - Hexadecimal string that gets sent"
+);
\ No newline at end of file
