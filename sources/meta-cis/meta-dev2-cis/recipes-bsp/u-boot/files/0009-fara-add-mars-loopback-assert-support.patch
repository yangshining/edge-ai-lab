+#include <console.h>
+#include <net.h>
+#include <net/loopback.h>
+
+static int do_loopback_assert(int argc, char *const argv[])
+{
+	loopback_state_set(1);
+	net_loop(LOOPBACK);
+	loopback_state_set(0);
+
+	return CMD_RET_SUCCESS;
+}
+
+static int do_ethloop(struct cmd_tbl *cmdtp, int flag, int argc,
+		       char *const argv[])
+{
+	return do_loopback_assert(argc, argv);
+}
