diff --git a/arch/arm/mach-versal/include/mach/hardware.h b/arch/arm/mach-versal/include/mach/hardware.h
index 10d32dfb3fc..c4e665f0398 100644
--- a/arch/arm/mach-versal/include/mach/hardware.h
+++ b/arch/arm/mach-versal/include/mach/hardware.h
@@ -105,3 +105,25 @@ struct crp_regs {
 #define PMC_GLOBAL_PGGS4_REG	0xF1110060
 
 #define OSPI_CTRL_RST		0xF1260304
+
+/* Reset Reason Mask */
+/*
+ * PMC_GLOBAL Base Address
+ */
+#ifndef PMC_GLOBAL_BASEADDR
+#define PMC_GLOBAL_BASEADDR     (0XF1110000U)
+#endif
+/*
+ * Register: PMC_GLOBAL_PERS_GEN_STORAGE2
+ */
+#define PMC_GLOBAL_PERS_GEN_STORAGE2	(PMC_GLOBAL_BASEADDR + 0X00000058U)
+
+#define RESET_REASON_MASK				(0x0000FFFFU)
+#define RESET_REASON_SLR_SYS			BIT(10)
+#define RESET_REASON_SW_SYS				BIT(9)
+#define RESET_REASON_ERR_SYS			BIT(8)
+#define RESET_REASON_DAP_SYS			BIT(7)
+#define RESET_REASON_ERR_POR			BIT(3)
+#define RESET_REASON_SLR_POR			BIT(2)
+#define RESET_REASON_SW_POR				BIT(1)
+#define RESET_REASON_EXTERNAL_POR		BIT(0)
diff --git a/board/xilinx/versal/board.c b/board/xilinx/versal/board.c
index 1227f000351..c0f6fda4316 100644
--- a/board/xilinx/versal/board.c
+++ b/board/xilinx/versal/board.c
@@ -59,6 +59,53 @@ static u8 versal_get_bootmode(void)
 	return bootmode;
 }
 
+static const struct {
+	u32 bit;
+	const char *name;
+} reset_reasons[] = {
+	{ RESET_REASON_SLR_SYS, "SLR" },
+	{ RESET_REASON_SW_SYS, "SOFT" },
+	{ RESET_REASON_ERR_SYS, "PMU" },
+	{ RESET_REASON_DAP_SYS, "DAP" },
+	{ RESET_REASON_ERR_POR, "PMC_POR" },
+	{ RESET_REASON_SLR_POR, "SLR_POR" },
+	{ RESET_REASON_SW_POR, "SW_POR" },
+	{ RESET_REASON_EXTERNAL_POR, "EXTERNAL" },
+	{}
+};
+
+static int reset_reason(void)
+{
+	u32 reg;
+	int i, ret;
+	const char *reason = NULL;
+
+	/* Reset reason reg was handled by plm and store reset reason value in PMC_GLOBAL_PERS_GEN_STORAGE2 */
+	reg = readl((ulong)PMC_GLOBAL_PERS_GEN_STORAGE2);
+
+	puts("Reset reason:\t");
+
+	for (i = 0; i < ARRAY_SIZE(reset_reasons); i++) {
+		if (reg & reset_reasons[i].bit) {
+			reason = reset_reasons[i].name;
+			printf("%s ", reset_reasons[i].name);
+			break;
+		}
+	}
+
+	puts("\n");
+
+	const char *current_reason = env_get("reset_reason");
+	if (!current_reason || strcmp(current_reason, reason) != 0 )
+	{
+		printf("Set reset reason: %s, previous: %s.\n", reason, current_reason);
+		env_set("reset_reason", reason);
+		env_set("bootenv_save", "true"); //save env later;
+	}
+
+	return 0;
+}
+
 static u32 versal_multi_boot(void)
 {
 	u8 bootmode = versal_get_bootmode();
@@ -307,6 +354,8 @@ int board_late_init(void)
 			return ret;
 	}
 
+	reset_reason();
+
 	return board_late_init_xilinx();
 }
 
