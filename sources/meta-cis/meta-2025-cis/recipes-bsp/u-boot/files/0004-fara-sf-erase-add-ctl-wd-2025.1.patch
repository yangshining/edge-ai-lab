diff --git a/cmd/sf.c b/cmd/sf.c
index e93c082692e..8f49af2bfea 100644
--- a/cmd/sf.c
+++ b/cmd/sf.c
@@ -22,6 +22,8 @@
 
 #include <asm/io.h>
 #include <dm/device-internal.h>
+#include <wdt.h>
+#include <watchdog.h>
 
 #include "legacy-mtd-utils.h"
 
@@ -633,10 +635,17 @@ static int do_spi_flash(struct cmd_tbl *cmdtp, int flag, int argc,
 	}
 
 	if (strcmp(cmd, "read") == 0 || strcmp(cmd, "write") == 0 ||
-	    strcmp(cmd, "update") == 0)
-		ret = do_spi_flash_read_write(argc, argv);
-	else if (strcmp(cmd, "erase") == 0)
-		ret = do_spi_flash_erase(argc, argv);
+	    strcmp(cmd, "update") == 0) {
+#if CONFIG_IS_ENABLED(WDT)
+		wdt_stop_all();
+#endif
+ 		ret = do_spi_flash_read_write(argc, argv);
+	}	else if (strcmp(cmd, "erase") == 0) {
+#if CONFIG_IS_ENABLED(WDT)
+		wdt_stop_all();
+#endif
+ 		ret = do_spi_flash_erase(argc, argv);
+	}
 	else if (IS_ENABLED(CONFIG_SPI_FLASH_LOCK) && strcmp(cmd, "protect") == 0)
 		ret = do_spi_protect(argc, argv);
 	else if (IS_ENABLED(CONFIG_SPI_FLASH_LOCK) && strcmp(cmd, "lockinfo") == 0)
@@ -646,6 +655,10 @@ static int do_spi_flash(struct cmd_tbl *cmdtp, int flag, int argc,
 	else
 		ret = CMD_RET_USAGE;
 
+#if CONFIG_IS_ENABLED(WDT)
+		initr_watchdog();
+		init_func_watchdog_reset();
+#endif
 	return ret;
 }
 
