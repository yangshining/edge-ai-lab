+static int
+ipcd_swap_upgrade(struct ubus_context *ctx, struct ubus_object *obj,
+					struct ubus_request_data *req, const char *method,
+					struct blob_attr *msg) {
+	int slot = -1;
+	char *filename = COMM_PACKAGE_IMAGE;
+	char slotPath[64] = {0};
+	char mountinfo[64];
+	char mmc_path[128];
+	char new_mmc_path[128];
+	struct head_blob head_info;
+	char head_buf[SLOTHEAD_SIZE];
+	int crc = 0;
+	int ret;
+	static struct blob_attr *tb[__IPC_SWAP_MAX];
+	blobmsg_parse(ipc_swap_upgrade_policy, __IPC_SWAP_MAX, tb,
+		blob_data(msg), blob_len(msg));
+	
+	if (tb[IPC_SWAP_SLOT]) {
+		slot = blobmsg_get_u32(tb[IPC_SWAP_SLOT]);
+		if (slot < 0) {
+			ret = UBUS_STATUS_INVALID_ARGUMENT;
+			goto err_out;
+		}
+	}
+	if (tb[IPC_SWAP_FILE]) {
+		filename = blobmsg_get_string(tb[IPC_SWAP_FILE]);
+	}
+
+	ipc_slot_upgrade_status(ctx, filename, slot, EVENT_STATUS_STARTING, req);
+
+	snprintf(slotPath, sizeof(slotPath), "/dev/mmcblk0p%d", slot + MMC_OFFSET);
+	if (get_mount_info(slotPath, mountinfo, NULL, NULL)) {
+		printf("MMC slot[%s] not mounted!\n", slotPath);
+		ret = UBUS_STATUS_INVALID_ARGUMENT;
+		goto err_out;
+	}
+
+	snprintf(new_mmc_path, sizeof(new_mmc_path), "%s/%s", mountinfo, filename);
+	memset(&head_info, 0, sizeof(struct head_blob));
+	if (access(new_mmc_path, F_OK) != 0 || check_file(new_mmc_path, &head_info, head_buf, crc)) {
+		printf("New package[%s] invalid!\n", filename);
+		ret = UBUS_STATUS_NO_DATA;
+		goto err_out;
+	}
+
+	snprintf(mmc_path, sizeof(mmc_path), "%s/%s", mountinfo, TOOL_PACKAGE_IMAGE);
+	if (access(mmc_path, F_OK) == 0) {
+		if (remove(mmc_path) != 0) {
+			printf("Clear obsolete lm.bin failed!\n");
+			ret = UBUS_STATUS_NOT_SUPPORTED;
+			goto err_out;
+		} 
+	} else {
+		printf("No obsolete lm.bin exist!\n");
+		ret = UBUS_STATUS_NOT_SUPPORTED;
+		goto err_out;
+	}
+
+	if (rename(new_mmc_path, mmc_path) == 0) {
+		printf("Slot swap successful!\n");
+	} else {
+		printf("Slot swap failed!\n");
+		ret = UBUS_STATUS_NOT_SUPPORTED;
+		goto err_out;
+	}
+
+    ipc_slot_upgrade_status(ctx, mmc_path, slot, EVENT_STATUS_SUCCESSFUL, req);
+	return UBUS_STATUS_OK;
+
+err_out:
+	ipc_slot_upgrade_status(ctx, mmc_path, slot, EVENT_STATUS_FAILED, req);
+	return ret;
+}
