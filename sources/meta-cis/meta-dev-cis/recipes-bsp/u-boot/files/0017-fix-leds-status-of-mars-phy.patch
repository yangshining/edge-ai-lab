From 6e1e929bc48dbd63474fdf1d8a4888675024534c Mon Sep 17 00:00:00 2001
From: hexi <xi.he@zillnk.com>
Date: Tue, 18 Oct 2022 14:23:51 +0800
Subject: [PATCH 1/1] fix leds status of mars phy

Change-Id: I4ea9bac3f736d45230b0e5f720f8d0aa746e3b4f
---
 drivers/net/phy/mars.c | 26 ++++++++++++++++++++------
 1 file changed, 20 insertions(+), 6 deletions(-)

diff --git a/drivers/net/phy/mars.c b/drivers/net/phy/mars.c
index 03ad9a48..ff8cf46e 100644
--- a/drivers/net/phy/mars.c
+++ b/drivers/net/phy/mars.c
@@ -37,6 +37,12 @@
 #define SLEEP_MODE		BIT(15)
 #define EXT_REG_BIT4	BIT(4)
 
+#define CONFIG_SW_MARS_LEDS 1
+
+#define CTC_PHY_LED_STATUS_BRIGHT 0xd800
+#define CTC_PHY_LED_STATUS_BRIGHT_FLASH 0xde00
+#define CTC_PHY_LED_STATUS_OFF_FLASH 0xe600
+
 static int mars_ext_read(struct phy_device *phydev, u32 regnum)
 {
 	int ret;
@@ -122,11 +128,20 @@ static int mars_set_link_timer_2_6ms(struct phy_device *phydev)
 	return 0;
 }
 
-static void led_setup(struct phy_device *phydev)
+/*
+ *LED0: 0xa00c
+ *LED1: 0xa00d
+ *LED2: 0xa00e
+ */
+static void mars_led_setup(struct phy_device *phydev)
 {
-	mars_ext_write(phydev, 0xa00d, 0xde00);
-	mars_ext_write(phydev, 0xa00e, 0xd800);
-
+#ifdef CONFIG_SW_MARS_LEDS
+	mars_ext_write(phydev, 0xa00d, CTC_PHY_LED_STATUS_BRIGHT);
+	mars_ext_write(phydev, 0xa00e, CTC_PHY_LED_STATUS_BRIGHT_FLASH);
+#else
+	mars_ext_write(phydev, 0xa00d, CTC_PHY_LED_STATUS_BRIGHT_FLASH);
+	mars_ext_write(phydev, 0xa00e, CTC_PHY_LED_STATUS_BRIGHT);
+#endif
 	return;
 }
 
@@ -154,8 +169,7 @@ int mars_config(struct phy_device *phydev)
 	features = (SUPPORTED_TP | SUPPORTED_MII
 			| SUPPORTED_AUI | SUPPORTED_FIBRE |
 			SUPPORTED_BNC);
-
-	led_setup(phydev);
+	mars_led_setup(phydev);
 	/* Do we support autonegotiation? */
 	val = phy_read(phydev, MDIO_DEVAD_NONE, MII_BMSR);
 
-- 
2.31.1

