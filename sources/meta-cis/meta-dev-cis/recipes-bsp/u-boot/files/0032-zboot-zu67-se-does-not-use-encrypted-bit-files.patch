From c84b30a4aa2d0d365f81bef54595ce7b098a1b8f Mon Sep 17 00:00:00 2001
From: hexi <xi.he@zillnk.com>
Date: Tue, 9 Jan 2024 11:07:25 +0800
Subject: [PATCH 1/1] zboot: zu67-se does not use encrypted bit files

---
 cmd/Kconfig | 6 ++++++
 cmd/zboot.c | 6 ++++++
 2 files changed, 12 insertions(+)

diff --git a/cmd/Kconfig b/cmd/Kconfig
index 92cacaf1..ba1ca427 100644
--- a/cmd/Kconfig
+++ b/cmd/Kconfig
@@ -795,6 +795,12 @@ config ZU67_SELECTION
 	help
 	  Automatically loads the zu67 limited and standard bit files.
 
+config ZU67_SE_FPGA_LOAD
+	bool "zu67-se fpga load"
+	depends on CMD_ZBOOT_Z
+	help
+	  zu67-se does not use encrypted bit files.
+
 endmenu
 
 menu "Device access commands"
diff --git a/cmd/zboot.c b/cmd/zboot.c
index 7ca6521a..aab159ca 100644
--- a/cmd/zboot.c
+++ b/cmd/zboot.c
@@ -220,11 +220,17 @@ static int do_fpga_loadb(uint32_t fpgadata, uint32_t datasize)
 		return -1;
 	}
 
+#ifdef CONFIG_ZU67_SE_FPGA_LOAD
+	return fpga_loadbitstream(dev, (void *)fpgadata, datasize, BIT_FULL);
+#else
+
 #ifdef CONFIG_ZBOOT_RSA_BITSTREAM
 	return do_fpga_loads_rsa_bitstream(dev, fpgadata, datasize);
 #else
 	return fpga_loadbitstream(dev, (void *)fpgadata, datasize, BIT_FULL);
 #endif
+
+#endif
 }
 
 static int parse_head_data(uint32_t base_addr, uint8_t fpganum)
-- 
2.31.1

