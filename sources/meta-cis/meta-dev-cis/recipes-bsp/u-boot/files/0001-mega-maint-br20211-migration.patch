+static int do_zboot(struct cmd_tbl *cmdtp, int flag, int argc, char * const argv[])
+{
+	slot_head *sh;
+	uint32_t base_addr, image_addr, fpga_data_addr, unzip_data_addr, local_data_size;
+	uint32_t fpga_data_size = 0, unzip_data_size = ~0UL;
+	uint32_t *checksum, *crc_len;
+	uint8_t *dataptr, *crc_data;
+	uint8_t length;
+
+	base_addr = simple_strtol(argv[1], NULL, 16);
+	if (!base_addr) {
+		printf("%s: zero zboot_data address\n", __func__);
+		return CMD_RET_USAGE;
+	}
+
+	local_data_size = simple_strtoul(argv[2], NULL, 16);
+	if (!local_data_size) {
+		printf("%s: zero size\n", __func__);
+		return CMD_RET_USAGE;
+	}
+
+	if (*((uint32_t *)base_addr) != FILE_HEAD) {
+		printf("%s: unrecognized file type!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	dataptr = (uint8_t*)base_addr;
+	length = (*dataptr << 8) + *(dataptr + 4);
+	dataptr += length;
+	dataptr += 4;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	checksum = (uint32_t *)(dataptr);
+	crc_data = (uint8_t *)(dataptr);
+	dataptr += 4;
+
+	crc_len = (uint32_t *)(dataptr);
+	dataptr += 4;
+
+	if (*((uint32_t *)dataptr) > local_data_size) {
+		printf("%s: CRC parameter error!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	crc_data = crc_data + *((uint32_t *)(dataptr));
+
+	if (*checksum != crc32(0, crc_data, *crc_len)){
+		printf("%s: CRC check error!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	/* skip the first bytes, their meaning is unknown */
+	length = (*dataptr << 8) + *(dataptr + 4);
+	dataptr += 4;
+	dataptr += length;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	if (*dataptr++ != 0x5A) {
+		printf("%s: Design data id not recognized\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	length = (*dataptr << 8) + *(dataptr + 1);
+	dataptr += 2;
+
+	printf("  version information = \"%s\"\n", dataptr);
+	dataptr += length;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	/* get part version */
+	if (*dataptr++ != 0X4C) {
+		printf("%s: Part version id not recognized\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	length = (*dataptr << 8) + *(dataptr + 1);
+	dataptr += 2;
+	printf("  version = %s\n", dataptr);
+
+	dataptr += length;
+	dataptr++;
+
+	LEGAL_ADDR(base_addr, dataptr);
+
+	sh = (slot_head *)dataptr;
+
+	fpga_data_addr = base_addr + sh->bit_offset + sh->head_size;
+	fpga_data_size = sh->bit_size;
+
+	/* Reserved 10M, */
+	unzip_data_addr = fpga_data_addr + fpga_data_size + SZ_10M;
+
+	/* 8 byte align */
+	BYTES_ALIGN(unzip_data_addr);
+
+	/**
+	 * gunzip() - Decompress gzipped data
+	 *
+	 * @dst: Destination for uncompressed data
+	 * @dstlen: Size of destination buffer
+	 * @src: Source data to decompress
+	 * @lenp: Returns length of uncompressed data
+	 * @return 0 if OK, -1 on error
+	 */
+	if (gunzip((void *)unzip_data_addr, ~0UL, (void *)fpga_data_addr, &unzip_data_size) != 0) {
+		printf("%s: Failure to decompress!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+	/* load fpga */
+	if(0 != do_fpga_loadb(unzip_data_addr, unzip_data_size))
+	{
+		printf("%s: FPGA configuration error!\n", __func__);
+		return CMD_RET_FAILURE;
+	}
+
+#ifdef CONFIG_CLU_INIT
+	printf("CLU config...\r\n");
+	clu_init();
+#endif
+
+	image_addr = base_addr + sh->head_size + sh->kernel_offset;
+
+	env_set("zboot_ver", ZBOOT_VERSION);
+	env_set("zboot_info", ZBOOT_INFO);
+	env_save();
+	/* boot kernel */
+
+	to_bootm(image_addr);
+
+	return 0;
+}
+
+U_BOOT_CMD(
+	zboot,	3,	0,	do_zboot,
+	"zboot starts the system",
+	"[<addr>] [<size> <CRU>] - Boot kernel parameters\n"
+	"<addr>     - memory address of the boot\n"
+	"<size>     - Size of mirror image\n"
+	"Version: " ZBOOT_VERSION "\n"
+	"Info: " ZBOOT_INFO "\n"
+);
