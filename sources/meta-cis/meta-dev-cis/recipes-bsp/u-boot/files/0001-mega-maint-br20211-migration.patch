+static long get_fpga_device(char *arg)
+{
+	long dev = FPGA_INVALID_DEVICE;
+	char *devstr = env_get("fpga");
+
+	if (devstr)
+		/* Should be strtol to handle -1 cases */
+		dev = simple_strtol(devstr, NULL, 16);
+
+	if (dev == FPGA_INVALID_DEVICE && arg)
+		dev = simple_strtol(arg, NULL, 16);
+
+	printf("%s: device = %ld\n", __func__, dev);
+
+	return dev;
+}
+
+static int do_fpga_loads_rsa_bitstream(int devnum, uint32_t fpga_data, uint32_t data_size)
+{
+	struct fpga_secure_info fpga_sec_info;
+	
+	memset(&fpga_sec_info, 0, sizeof(fpga_sec_info));
+	/*
+	*	auth_loc :
+	*
+	*	location of image to be authenticated is located
+	*
+	*	0 = On-Chip Memory (OCM)
+	*
+	*	1 = DDR
+	*
+	*	2 = no authentication
+	*/
+	fpga_sec_info.authflag = 1; //DDR
+	/*
+	* enc_key_sel :
+	*
+	* selection of the encryption key
+	*
+	* 0 = device key
+	*
+	* 1 = user key - KUP
+	*
+	* 2 = no encryption
+	*/
+	fpga_sec_info.encflag = 2;
+	printf("fpga load rsa bitstream.\n");
+	return fpga_loads(devnum, (void *)fpga_data, data_size, &fpga_sec_info);
+}
+
+static int do_fpga_loadb(uint32_t fpgadata, uint32_t datasize)
+{
+	long dev;
+
+	/* use device zero */
+	dev = get_fpga_device("0");
+	if (dev < 0) {
+		printf("ERROR git fpga device failed!\n");
+		return -1;
+	}
+#ifdef CONFIG_ZBOOT_RSA_BITSTREAM
+	return do_fpga_loads_rsa_bitstream(dev, fpgadata, datasize);
+#else
+	return fpga_loadbitstream(dev, (void *)fpgadata, datasize, BIT_FULL);
+#endif
+}
+
+static int to_bootm(uint32_t image_addr)
+{
+	int ret = 0;
+	char *bootm_argv[2];
+	char boot_addr[16];
+	/* create paramter array */
+	bootm_argv[0] = "bootm";
+	bootm_argv[1] = boot_addr;
+
+
+	snprintf(boot_addr, sizeof(boot_addr), "0x%lx", image_addr);
+
+	ret = do_bootm(find_cmd("do_bootm"), 0, 2,
+			bootm_argv);
+
+	if (ret) {
+		printf("ERROR prep subcommand failed!\n");
+		return -1;
+	}
+	return 0;
+}
