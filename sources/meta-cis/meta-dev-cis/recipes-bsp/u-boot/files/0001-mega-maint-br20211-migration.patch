+static int do_sftest(struct cmd_tbl *cmdtp, int flag, int argc,
+			char * const argv[])
+{
+	char *endp;
+	int ret;
+	u8 *buf, *from, *vbuf;
+	unsigned base_ms, time_ms;
+	ulong start, end, count, len, i;
+
+	if (argc < 2)
+		return -1;
+
+	start = simple_strtoul(argv[1], &endp, 16);
+	if (*argv[1] == 0 || *endp != 0)
+		return -1;
+
+	len = simple_strtoul(argv[2], &endp, 16);
+	if (*argv[2] == 0 || *endp != 0)
+		return -1;
+
+	count = simple_strtoul(argv[3], &endp, 16);
+	if (*argv[3] == 0 || *endp != 0)
+		return -1;
+
+	end = start + len;
+	vbuf = memalign(ARCH_DMA_MINALIGN, len);
+	if (!vbuf) {
+		printf("Cannot allocate memory (%lu bytes)\n", len);
+		return 1;
+	}
+
+	buf = memalign(ARCH_DMA_MINALIGN, len);
+	if (!buf) {
+		free(vbuf);
+		printf("Cannot allocate memory (%lu bytes)\n", len);
+		return 1;
+	}
+
+	from = map_sysmem(CONFIG_SYS_TEXT_BASE, 0);
+	memcpy(buf, from, len);
+
+	/* The remaining commands require a selected device */
+	if (!flash) {
+		puts("No SPI flash selected. Please run `sf probe'\n");
+		return 1;
+	}
+
+	base_ms = get_timer(0);
+	printf("SPI flash test:\n");
+	for (i = 1; i <= count; i++) {
+		if (i % 100 == 0) {
+			time_ms = get_timer(base_ms);
+			printf("Testing 0x%08lx - 0x%08lx %u ticks count: %ld\n", start, end, time_ms, i);
+			base_ms = get_timer(0);
+		}
+
+		ret = spi_flash_test(flash, buf, len, start, vbuf);
+		if (ret)
+			goto err;
+	}
+
+err:
+	printf("\n");
+	printf("Tested %ld count(s), Test %s .\n", i - 1, ret ? "failed" : "passed");
+	free(vbuf);
+	free(buf);
+	return ret;
+}
+
+U_BOOT_CMD(
+	sftest,	4,	1,	do_sftest,
+	"spi flash read/write test",
+	"offset  len  count"
+);
diff --git a/cmd/zboot.c b/cmd/zboot.c
new file mode 100644
index 00000000..9854a101
--- /dev/null
+++ b/cmd/zboot.c
@@ -0,0 +1,381 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * (C) Copyright 2020
+ * Ma Chun <chun.ma@zillnk.com>, Zillnk Inc.
+ */
+#include "zboot.h"
+
+static int do_spi_xfer(uchar *dout, uchar *din, int bitlen)
+{
+	struct spi_slave *slave;
+	int ret = 0;
+
+#ifdef CONFIG_DM_SPI
+	char name[30], *str;
+	struct udevice *dev;
+
+	snprintf(name, sizeof(name), "generic_%d:%d", BUS, CS);
+	str = strdup(name);
+	if (!str)
+		return -ENOMEM;
+	ret = spi_get_bus_and_cs(BUS, CS, 1000000, MODE, "spi_generic_drv",
+				 str, &dev, &slave);
+	if (ret)
+		return ret;
+#else
+	slave = spi_setup_slave(BUS, CS, 1000000, MODE);
+	if (!slave) {
+		printf("Invalid device %d:%d\n", BUS, CS);
+		return -EINVAL;
+	}
+#endif
+
+	ret = spi_claim_bus(slave);
+	if (ret)
+		goto done;
+	ret = spi_xfer(slave, bitlen, dout, din,
+			SPI_XFER_BEGIN | SPI_XFER_END);
+#ifndef CONFIG_DM_SPI
+	/* We don't get an error code in this case */
+	if (ret)
+		ret = -EIO;
+#endif
+	if (ret) {
+		printf("Error %d during SPI transaction\n", ret);
+	}
+
+done:
+	spi_release_bus(slave);
+#ifndef CONFIG_DM_SPI
+	spi_free_slave(slave);
+#endif
+
+	return ret;
+}
+
+static int spi_read(uint32_t addr, uint16_t *value)
+{
+	uint32_t sig = 0;
+	uchar *re_sig = (uchar *)&sig;
+	uchar din[MAX_SPI_BYTES];
+
+	re_sig[0] = 0x80 | ((0xffff & addr) >> 8);
+	re_sig[1] = 0xff & (uchar)addr;
+
+	do_spi_xfer(re_sig, &din, BITLEN);
+	*value = *(din + (BITLEN / 8 - 1));
+	return 0;
+}
+
+static int spi_write(uchar *dout)
+{
+	uchar din[MAX_SPI_BYTES];
+	return do_spi_xfer(dout, &din, BITLEN);
+}
+
+static int clu_init()
+{
+	int i, ret;
+	uint8_t value = 0;
+
+	for(i = 0; i < (sizeof(reg_data) / sizeof(reg_data[0])); i++){
+		spi_write(&reg_data[i]);
+		udelay(5000);
+	}
+
+	udelay(500000);
+
+	/* check SYCCLK and PLL status*/
+	ret = spi_read(0x3001, &value);
+	if (ret) {
+		printf("read reg[0x3001] faild %d\n", ret);
+		return ret;
+	}
+
+	if ((value & SYSCLK_PLL_MASK) != SYSCLK_PLL_OK) {
+		printf("SYSCLK PLL status [0x%x]not OK\n", value);
+		return 1;
+	}
+
+	spi_write("\x21\x00\x00");
+	spi_write("\x00\x0F\x01");
+	spi_write("\x21\x00\x02");
+	spi_write("\x00\x0F\x01");
+
+	udelay(500000);
+
+	/* check PLL0 status*/
+	value = 0;
+	ret = spi_read(0x3100, &value);
+	if (ret) {
+		printf("read reg[0x3100] faild %d\n", ret);
+		return ret;
+	}
+
+	if ((value & PLL0_LOCK_MASK) != PLL0_LOCK_OK) {
+		printf("PLL0 Lock status [0x%x]not OK\n", value);
+		return 1;
+	}
+
+	spi_write("\x22\x00\x00");
+	spi_write("\x00\x0F\x01");
+	spi_write("\x22\x00\x02");
+	spi_write("\x00\x0F\x01");
+
+	udelay(500000);
+
+	/* check PLL1 status*/
+	value = 0;
+	ret = spi_read(0x3200, &value);
+	if (ret) {
+		printf("read reg[0x3200] faild %d\n", ret);
+		return ret;
+	}
+
+	if ((value & PLL1_LOCK_MASK) != PLL1_LOCK_OK) {
+		printf("PLL1 Lock status [0x%x]not OK\n", value);
+		return 1;
+	}
+
+	spi_write("\x02\x84\x02");
+	spi_write("\x00\x0F\x01");
+
+	printf("CLU OK!\n");
+	return 0;
+
+}
