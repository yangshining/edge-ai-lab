+#include <config.h>
+#include <common.h>
+#include <errno.h>
+#include <phy.h>
+#include <net/loopback.h>
+#include <linux/delay.h>
+
+#define CTC_PHY_REG_SPACE  0
+#define CTC_SDS_REG_SPACE 1
+
+ /* Mask used for ID comparisons */
+#define CTC_PHY_ID_MASK		0xffffffff
+
+/* Known PHY IDs */
+#define CTC_PHY_ID_MARS1S_V1        0x00782013
+#define CTC_PHY_ID_MARS1S           0x01E04013
+#define CTC_PHY_ID_MARS1P_V1        0x00782011
+#define CTC_PHY_ID_MARS1P           0x01E04011
+
+#define SLEEP_MODE		BIT(15)
+#define EXT_REG_BIT4	BIT(4)
+
+static int mars_ext_read(struct phy_device *phydev, u32 regnum)
+{
+	int ret;
+
+	ret = phy_write(phydev, MDIO_DEVAD_NONE, 0x1e, regnum);
+	if(ret<0)
+		return ret;
+
+	return phy_read(phydev, MDIO_DEVAD_NONE, 0x1f);
+}
+
+static int mars_ext_write(struct phy_device *phydev, u32 regnum, u16 val)
+{
+	int ret;
+
+	ret = phy_write(phydev, MDIO_DEVAD_NONE, 0x1e, regnum);
+	if(ret<0)
+		return ret;
+
+	return phy_write(phydev, MDIO_DEVAD_NONE, 0x1f, val);
+}
+
+void mars_loopback(struct phy_device *phydev)
+{
+	int val;
+
+	val = mars_ext_read(phydev, 0x27);
+	val &= ~(SLEEP_MODE);
+	mars_ext_write(phydev, 0x27, val);
+
+	val = mars_ext_read(phydev, 0xa);
+	val |= EXT_REG_BIT4;
+	mars_ext_write(phydev, 0xa, val);
+
+	val = phy_read(phydev, MDIO_DEVAD_NONE, MII_BMCR);
+	val &= ~(BMCR_CTST | BMCR_ANRESTART | BMCR_ANENABLE | BMCR_SPEED100);
+	val |= (BMCR_FULLDPLX | BMCR_SPEED1000 | BMCR_RESET);
+
+	phy_write(phydev, MDIO_DEVAD_NONE, MII_BMCR, val);
+}
+
+void mars_loopback_off(struct phy_device *phydev)
+{
+	int val;
+
+	val = mars_ext_read(phydev, 0x27);
+	val |= SLEEP_MODE;
+	mars_ext_write(phydev, 0x27, val);
+
+	val = mars_ext_read(phydev, 0xa);
+	val &= ~(EXT_REG_BIT4);
+	mars_ext_write(phydev, 0xa, val);
+
+	val = phy_read(phydev, MDIO_DEVAD_NONE, MII_BMCR);
+	val |= (BMCR_ANENABLE | BMCR_ANRESTART | BMCR_RESET);
+	val &= ~(BMCR_ISOLATE);
+
+	phy_write(phydev, MDIO_DEVAD_NONE, MII_BMCR, val);
+}
+
+static int mars_select_reg_space(struct phy_device *phydev, int space)
+{
+	int ret;
+
+	if (space == CTC_PHY_REG_SPACE){
+		ret = mars_ext_write(phydev, 0xa000, 0x0);
+	}else{
+		ret = mars_ext_write(phydev, 0xa000, 0x2);
+	}
+
+	return ret;
+}
+
+static int mars_set_link_timer_2_6ms(struct phy_device *phydev)
+{
+	int ret=0;
+
+	ret = mars_select_reg_space(phydev, CTC_SDS_REG_SPACE);
+	if(!ret)
+		mars_ext_write(phydev, 0xa5, 0x5);
+	mars_select_reg_space(phydev, CTC_PHY_REG_SPACE);
+
+	return 0;
+}
+
+static void led_setup(struct phy_device *phydev)
+{
+	mars_ext_write(phydev, 0xa00d, 0xde00);
+	mars_ext_write(phydev, 0xa00e, 0xd800);
+
+	return;
+}
+
+#if 0
+static int mars_set_link_timer_6_3ms(struct phy_device *phydev)
+{
+	int ret=0;
+
+	printf("mars_set_link_timer_6_3ms\n");
+	ret = mars_select_reg_space(phydev, CTC_SDS_REG_SPACE);
+	if(!ret)
+		mars_ext_write(phydev, 0xa5, 0xc);
+	mars_select_reg_space(phydev, CTC_PHY_REG_SPACE);
+
+	return 0;
+}
+#endif
+
+int mars_config(struct phy_device *phydev)
+{
+	int val;
+	u32 features;
+
+	mars_set_link_timer_2_6ms(phydev);
+	features = (SUPPORTED_TP | SUPPORTED_MII
+			| SUPPORTED_AUI | SUPPORTED_FIBRE |
+			SUPPORTED_BNC);
+
+	led_setup(phydev);
+	/* Do we support autonegotiation? */
+	val = phy_read(phydev, MDIO_DEVAD_NONE, MII_BMSR);
+
+	if (val < 0)
+		return val;
+
+	if (val & BMSR_ANEGCAPABLE)
+		features |= SUPPORTED_Autoneg;
+
+	if (val & BMSR_100FULL)
+		features |= SUPPORTED_100baseT_Full;
+	if (val & BMSR_100HALF)
+		features |= SUPPORTED_100baseT_Half;
+	if (val & BMSR_10FULL)
+		features |= SUPPORTED_10baseT_Full;
+	if (val & BMSR_10HALF)
+		features |= SUPPORTED_10baseT_Half;
+
+	if (val & BMSR_ESTATEN) {
+		val = phy_read(phydev, MDIO_DEVAD_NONE, MII_ESTATUS);
+
+		if (val < 0)
+			return val;
+
+		if (val & ESTATUS_1000_TFULL)
+			features |= SUPPORTED_1000baseT_Full;
+		if (val & ESTATUS_1000_THALF)
+			features |= SUPPORTED_1000baseT_Half;
+		if (val & ESTATUS_1000_XFULL)
+			features |= SUPPORTED_1000baseX_Full;
+		if (val & ESTATUS_1000_XHALF)
+			features |= SUPPORTED_1000baseX_Half;
+	}
+
+	phydev->supported &= features;
+	phydev->advertising &= features;
+
+	genphy_config_aneg(phydev);
+
+	return 0;
+}
+
+int mars1p_config(struct phy_device *phydev)
+{
+	/*RGMII clock 2.5M when link down, bit12:1->0*/
+	mars_ext_write(phydev, 0xc, 0x8051);
+	/*Disable sleep mode, bit15:1->0*/
+	mars_ext_write(phydev, 0x27, 0x2029);
+	/* disable PHY to respond to MDIO access with PHYAD0 */
+    /* MMD7 8001h: bit6: 0, change value: 0x7f --> 0x3f */
+	phy_write(phydev, MDIO_DEVAD_NONE, 0xd, 0x7);
+	phy_write(phydev, MDIO_DEVAD_NONE, 0xe, 0x8001);
+	phy_write(phydev, MDIO_DEVAD_NONE, 0xd, 0x4007);
+	phy_write(phydev, MDIO_DEVAD_NONE, 0xe, 0x3f);
+
+	return mars_config(phydev);
+}
+
+int mars_startup(struct phy_device *phydev)
+{
+	unsigned int mii_reg;
+	int i = 0;
+
+	mars_select_reg_space(phydev, CTC_SDS_REG_SPACE);
+	mars_ext_write(phydev, 0x3, 0x670);
+	mars_select_reg_space(phydev, CTC_PHY_REG_SPACE);
+
+	if (loopback_mode()) {
+		mars_loopback(phydev);
+
+		phydev->asym_pause = 0;
+		phydev->pause = 0;
+		phydev->duplex =DUPLEX_FULL;
+		phydev->speed = SPEED_1000;
+		phydev->link = 1;
+
+		/* fixed link must not be reset by core phy code */
+		phydev->flags |= PHY_FLAG_BROKEN_RESET;
+
+		mii_reg = phy_read(phydev, MDIO_DEVAD_NONE, MII_BMSR);
+		/*
+		 * If we already saw the link up, and it hasn't gone down, then
+		 * we don't need to wait for autoneg again
+		 */
+		if (phydev->link && mii_reg & BMSR_LSTATUS)
+			return 0;
+
+			while (!(mii_reg & BMSR_LSTATUS)) {
+				/*
+				 * Timeout reached ?
+				 */
+				if (i > 50) {
+					phydev->link = 0;
+					return -ETIMEDOUT;
+				}
+				i++;
+				mii_reg = phy_read(phydev, MDIO_DEVAD_NONE, MII_BMSR);
+				mdelay(50);
+			}
+
+		return 0;
+	}
+	else {
+		mars_loopback_off(phydev);
+		return genphy_startup(phydev);
+	}
+}
+
+static struct phy_driver mars1s_driver = {
+	.name = "CTC MARS1S",
+	.uid = CTC_PHY_ID_MARS1S,
+	.mask = CTC_PHY_ID_MASK,
+	.features = PHY_GBIT_FEATURES,
+	.config = &mars_config,
+	.startup = &mars_startup,
+	.shutdown = &genphy_shutdown,
+};
+static struct phy_driver mars1s_v1_driver = {
+	.name = "CTC MARS1S_V1",
+	.uid = CTC_PHY_ID_MARS1S_V1,
+	.mask = CTC_PHY_ID_MASK,
+	.features = PHY_GBIT_FEATURES,
+	.config = &mars_config,
+	.startup = &mars_startup,
+	.shutdown = &genphy_shutdown,
+};
+
+static struct phy_driver mars1p_driver = {
+	.name = "CTC MARS1P",
+	.uid = CTC_PHY_ID_MARS1P,
+	.mask = CTC_PHY_ID_MASK,
+	.features = PHY_GBIT_FEATURES,
+	.config = &mars1p_config,
+	.startup = &mars_startup,
+	.shutdown = &genphy_shutdown,
+};
+
+static struct phy_driver mars1p_v1_driver = {
+	.name = "CTC MARS1P_V1",
+	.uid = CTC_PHY_ID_MARS1P_V1,
+	.mask = CTC_PHY_ID_MASK,
+	.features = PHY_GBIT_FEATURES,
+	.config = &mars1p_config,
+	.startup = &mars_startup,
+	.shutdown = &genphy_shutdown,
+};
+
+int phy_mars_init(void)
+{
+	phy_register(&mars1s_driver);
+	phy_register(&mars1s_v1_driver);
+	phy_register(&mars1p_driver);
+	phy_register(&mars1p_v1_driver);
+
+	return 0;
+}
