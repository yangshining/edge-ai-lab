+
+/* wait timeout */
+#define WAIT_TIMEOUT 1500
+/* loopback port # defined in spec */
+#define WELL_PORT 1133
+
+#define PACK_SIZE	8
+
+static int loopback_state = 0;
+char *str_r;
+
+static void loopback_timeout_handler(void)
+{
+	loopback_state_set(0);
+	net_set_udp_handler(NULL);
+	net_set_arp_handler(NULL);
+	net_set_timeout_handler(0, NULL);
+	eth_halt();
+	/* Invalidate the last protocol */
+	eth_set_last_protocol(BOOTP);
+	net_start_again();
+}
+
+static inline void random_str(uchar *addr, u8 len)
+{
+	int i;
+	unsigned int seed = get_ticks();
+
+	for (i = 0; i < len; i++)
+		addr[i] = rand_r(&seed);
+}
+
+/**
+ * loopback_handler() - Incoming UDP packet handler.
+ *
+ * @packet: Pointer to incoming UDP packet
+ * @dport: Destination UDP port
+ * @sip: Source IP address
+ * @sport: Source UDP port
+ * @len: Packet length
+ */
+static void loopback_handler(uchar *packet, unsigned int dport,
+			     struct in_addr sip, unsigned int sport,
+			     unsigned int len)
+{
+	if ((dport != WELL_PORT) || (sport != WELL_PORT) ||
+			(len != PACK_SIZE))
+		return;
+
+	if (memcmp(str_r, packet, PACK_SIZE) == 0) {
+		env_set("Loopback", "yes");
+		printf("Loopback detected!\n");
+	}
+	else{
+		env_set("Loopback", "no");
+		printf("Loopback NOT detected!\n");
+	}
+
+	loopback_timeout_handler();
+}
+
+int loopback_mode(void)
+{
+	return loopback_state;
+}
+
+void loopback_state_set(int state)
+{
+	loopback_state = state;
+}
+
+void loopback_start_server(void)
+{
+	int i = 10;
+	int send_len = 0;
+	struct in_addr local_ip;
+	uchar *send_packet;
+	uchar *send_packet_base;
+
+	net_set_timeout_handler(WAIT_TIMEOUT, loopback_timeout_handler);
+	net_set_udp_handler(loopback_handler);
+
+	local_ip.s_addr = 0;
+	send_packet = net_tx_packet + net_eth_hdr_size() + IP_UDP_HDR_SIZE;
+	send_packet_base = send_packet;
+
+	str_r = malloc(PACK_SIZE);
+	if (!str_r) {
+		printf("Can't allocate memory to decrypt\n");
+		return -ENOMEM;
+	}
+	random_str(str_r, PACK_SIZE);
+
+	memcpy(send_packet, str_r, PACK_SIZE);
+	send_packet += PACK_SIZE;
+	send_len = send_packet - send_packet_base;
+
+	/* zero out server ether in case the server ip has changed */
+	memset(net_server_ethaddr, 0, 6);
+
+	while (i--) {
+		net_send_udp_packet(net_server_ethaddr, local_ip,
+							WELL_PORT, WELL_PORT,
+							send_len);
+		mdelay(50);
+	}
+}
