index 0000000000..12031bf5ce
--- /dev/null
+++ b/drivers/net/phy/switch-link.c
@@ -0,0 +1,403 @@
+//SPDX-License-Identifier: GPL-2.0+
+/*
+ * switch-Link phy
+ *
+ * Copyright 2022 zillnk
+ */
+
+#include <config.h>
+#include <common.h>
+#include <phy.h>
+#include <dm.h>
+#include <fdt_support.h>
+#include <asm/gpio.h>
+#include <zynqmp_firmware.h>
+#include <linux/delay.h>
+
+DECLARE_GLOBAL_DATA_PTR;
+
+#define CTC21101							0x782013
+#define TST0101								0x00011a
+#define RTL8211F							0x1cc916
+
+#define CTC21101_CDR_REG_VAL				0x750
+
+#define MIIM_RTL8211F_PAGE_SELECT			0x1f
+#define MIIM_RTL8211F_TX_DELAY				0x100
+
+#define MV88E6185_GLOBAL1_ADDR				0x1b
+#define MV88E6185_PORT_BASE_ADDR			0x10
+#define MV88E6185_NUM_PORTS					0x0a
+#define MV88E6185_PORT_SWITCH_ID			0x03
+#define MV88E6185_GLOBAL1_CTLl				0x04
+
+#define MV88E6185_PORT_SWITCH_ID_PROD_MASK	0xfff0
+#define MV88E6185_PORT_SWITCH_ID_PROD_6185	0x1a70
+
+#define MV88E6185_PORT_STS					0x0000
+#define MV88E6185_PORT_STS_PHY_DETECT		0x1000
+
+#define MV88E6185_PORT_MAC_CTL				0x0001
+#define MV88E6185_PORT_MAC_CTL_LINK_UP		0x0020
+#define MV88E6185_PORT_MAC_CTL_FORCE_LINK	0x0010
+#define MV88E6185_PORT_MAC_CTL_DUPLEX_FULL	0x0008
+#define MV88E6185_PORT_MAC_CTL_FORCE_DUPLEX	0x0004
+#define MV88E6185_PORT_MAC_CTL_SPEED_1000	0x0002
+
+#define MV88E6185_G1_CTL1_PPU_ENABLE		0x4000
+#define MV88E6185_G1_STS_PPU_STATE_MASK		0xc000
+#define MV88E6185_G1_STS_PPU_STATE_DISABLED	0x8000
+#define MV88E6185_G1_STS_PPU_STATE_POLLING	0xc000
+#define MV88E6185_G1_STS_PPU_STATE_BUSY		0x0000
+
+
+static inline int mv88e6185_port_read(struct phy_device *phydev, u8 port, u8 reg)
+{
+	struct mii_dev *bus = phydev->bus;
+	return bus->read(bus, (MV88E6185_PORT_BASE_ADDR + port), MDIO_DEVAD_NONE, reg);
+}
+
+static inline int mv88e6185_port_write(struct phy_device *phydev, u8 port, u8 reg, u16 val)
+{
+	struct mii_dev *bus = phydev->bus;
+	return bus->write(bus, (MV88E6185_PORT_BASE_ADDR + port), MDIO_DEVAD_NONE, reg, val);
+}
+
+static inline void mv88e6xxx_wait_mask(struct phy_device *phydev, u16 mask, u16 val)
+{
+	int i;
+	u16 buf;
+	struct mii_dev *bus = phydev->bus;
+
+	/* There's no bus specific operation to wait for a mask */
+	for (i = 0; i < 16; i++) {
+		buf = bus->read(bus, MV88E6185_GLOBAL1_ADDR, MDIO_DEVAD_NONE,
+		MV88E6185_G1_STS_PPU_STATE_BUSY);
+
+		if ((buf & mask) == val)
+			return;
+
+		mdelay(1);
+	}
+}
+
+static inline void mv88e6185_g1_wait_ppu_disabled(struct phy_device *phydev)
+{
+	mv88e6xxx_wait_mask(phydev, MV88E6185_G1_STS_PPU_STATE_MASK,
+	MV88E6185_G1_STS_PPU_STATE_DISABLED);
+}
+
+static inline void mv88e6185_g1_wait_ppu_polling(struct phy_device *phydev)
+{
+	mv88e6xxx_wait_mask(phydev, MV88E6185_G1_STS_PPU_STATE_MASK,
+	MV88E6185_G1_STS_PPU_STATE_POLLING);
+}
+
+static inline void mv88e6185_g1_ppu_disable(struct phy_device *phydev)
+{
+	u16 val;
+	struct mii_dev *bus = phydev->bus;
+
+	val =  bus->read(bus, MV88E6185_GLOBAL1_ADDR, MDIO_DEVAD_NONE, MV88E6185_GLOBAL1_CTLl);
+	val &= ~MV88E6185_G1_CTL1_PPU_ENABLE;
+	bus->write(bus, MV88E6185_GLOBAL1_ADDR, MDIO_DEVAD_NONE, MV88E6185_GLOBAL1_CTLl, val);
+	mv88e6185_g1_wait_ppu_disabled(phydev);
+}
+
+static inline void mv88e6185_g1_ppu_enable(struct phy_device *phydev)
+{
+	u16 val;
+	struct mii_dev *bus = phydev->bus;
+
+	val =  bus->read(bus, MV88E6185_GLOBAL1_ADDR, MDIO_DEVAD_NONE, MV88E6185_GLOBAL1_CTLl);
+	val |= MV88E6185_G1_CTL1_PPU_ENABLE;
+	bus->write(bus, MV88E6185_GLOBAL1_ADDR, MDIO_DEVAD_NONE, MV88E6185_GLOBAL1_CTLl, val);
+	mv88e6185_g1_wait_ppu_polling(phydev);
+}
+
+static inline int mv88e6185_phy_read(struct phy_device *phydev, u8 port, u8 reg)
+{
+	u16 val;
+	struct mii_dev *bus = phydev->bus;
+
+	mv88e6185_g1_ppu_disable(phydev);
+	val = bus->read(bus, port, MDIO_DEVAD_NONE, reg);
+	mv88e6185_g1_ppu_enable(phydev);
+	return val;
+}
+
+static inline int mv88e6185_phy_write(struct phy_device *phydev, u8 port, u8 reg, u16 val)
+{
+	u16 ret;
+	struct mii_dev *bus = phydev->bus;
+
+	mv88e6185_g1_ppu_disable(phydev);
+	ret = bus->write(bus, port, MDIO_DEVAD_NONE, reg, val);
+	mv88e6185_g1_ppu_enable(phydev);
+	return ret;
+}
+
+static inline int mars_ext_write(struct phy_device *phydev, u8 addr, u32 reg, u16 val)
+{
+	int ret;
+
+	ret = mv88e6185_phy_write(phydev, addr, 0x1e, reg);
+	if (ret < 0)
+		return ret;
+
+	return mv88e6185_phy_write(phydev, addr, 0x1f, val);
+}
+
+static void rtl8211f_phy_setup(struct phy_device *phydev, u8 addr)
+{
+	u16 ctl;
+
+	mv88e6185_phy_write(phydev, addr, MII_BMCR, BMCR_RESET);
+
+	mv88e6185_phy_write(phydev, addr, MIIM_RTL8211F_PAGE_SELECT, 0xd08);
+	ctl = mv88e6185_phy_read(phydev, addr, 0x11);
+	ctl &= ~MIIM_RTL8211F_TX_DELAY;
+
+	mv88e6185_phy_write(phydev, addr, 0x11, ctl);
+	/* restore to default page 0 */
+	mv88e6185_phy_write(phydev, addr, MIIM_RTL8211F_PAGE_SELECT, 0x0);
+
+	/* Set green LED for Link, yellow LED for Active */
+	mv88e6185_phy_write(phydev, addr, MIIM_RTL8211F_PAGE_SELECT, 0xd04);
+	mv88e6185_phy_write(phydev, addr, 0x10, 0x617f);
+	mv88e6185_phy_write(phydev, addr, MIIM_RTL8211F_PAGE_SELECT, 0x0);
+
+	ctl = mv88e6185_port_read(phydev, addr, MV88E6185_PORT_STS);
+	ctl |= MV88E6185_PORT_STS_PHY_DETECT;
+	mv88e6185_port_write(phydev, addr, MV88E6185_PORT_STS, ctl);
+
+	ctl = mv88e6185_phy_read(phydev, addr, MII_CTRL1000);
+	ctl &= ~(ADVERTISE_1000FULL | ADVERTISE_1000HALF);
+	ctl |= ADVERTISE_1000FULL;
+	mv88e6185_phy_write(phydev, addr, MII_CTRL1000, ctl);
+
+	ctl = mv88e6185_phy_read(phydev, addr, MII_BMCR);
+	ctl |= (BMCR_ANENABLE | BMCR_ANRESTART | BMCR_RESET);
+	ctl &= ~(BMCR_ISOLATE);
+
+	mv88e6185_phy_write(phydev, addr, MII_BMCR, ctl);
+}
+
+static void ctc21101_phy_setup(struct phy_device *phydev, u8 addr)
+{
+	u16 ctl;
+
+	mars_ext_write(phydev, addr, 0xa005, 0x0);
+
+	mars_ext_write(phydev, addr, 0xa00d, 0xde00);
+	mars_ext_write(phydev, addr, 0xa00e, 0xd800);
+
+	mars_ext_write(phydev, addr, 0xa000, 0x2);
+	mars_ext_write(phydev, addr, 0x3, CTC21101_CDR_REG_VAL);
+
+	mars_ext_write(phydev, addr, 0xa000, 0x0);
+
+	ctl = mv88e6185_port_read(phydev, addr, MV88E6185_PORT_STS);
+	ctl |= MV88E6185_PORT_STS_PHY_DETECT;
+	mv88e6185_port_write(phydev, addr, MV88E6185_PORT_STS, ctl);
+
+	ctl = mv88e6185_phy_read(phydev, addr, MII_CTRL1000);
+	ctl &= ~(ADVERTISE_1000FULL | ADVERTISE_1000HALF);
+	ctl |= ADVERTISE_1000FULL;
+	mv88e6185_phy_write(phydev, addr, MII_CTRL1000, ctl);
+
+	ctl = mv88e6185_phy_read(phydev, addr, MII_BMCR);
+	ctl |= (BMCR_ANENABLE | BMCR_ANRESTART | BMCR_RESET);
+	ctl &= ~(BMCR_ISOLATE);
+
+	mv88e6185_phy_write(phydev, addr, MII_BMCR, ctl);
+}
+
+static void mii_phy_setup(struct phy_device *phydev, u8 addr)
+{
+	u16 ctl;
+
+	ctl = mv88e6185_port_read(phydev, addr, MV88E6185_PORT_STS);
+	ctl |= MV88E6185_PORT_STS_PHY_DETECT;
+	mv88e6185_port_write(phydev, addr, MV88E6185_PORT_STS, ctl);
+
+	ctl = mv88e6185_phy_read(phydev, addr, MII_CTRL1000);
+	ctl &= ~(ADVERTISE_1000FULL | ADVERTISE_1000HALF);
+	ctl |= ADVERTISE_1000FULL;
+	mv88e6185_phy_write(phydev, addr, MII_CTRL1000, ctl);
+
+	ctl = mv88e6185_phy_read(phydev, addr, MII_BMCR);
+	ctl |= (BMCR_ANENABLE | BMCR_ANRESTART | BMCR_RESET);
+	ctl &= ~(BMCR_ISOLATE);
+	mv88e6185_phy_write(phydev, addr, MII_BMCR, ctl);
+}
+
+static int mv88e6185_phy_port_setup(struct phy_device *phydev, u8 port)
+{
+	u16 val;
+	u32 phy_id;
+
+	val = mv88e6185_phy_read(phydev, port, MII_PHYSID1);
+	phy_id = val;
+	val = mv88e6185_phy_read(phydev, port, MII_PHYSID2);
+	phy_id = (phy_id << 16);
+	phy_id |= val;
+
+	if (phy_id == ~((u32)0U))
+		return -ENOMEM;
+
+	if (phy_id == RTL8211F) {
+		rtl8211f_phy_setup(phydev, port);
+	}
+	else if (phy_id == CTC21101 || phy_id == TST0101) {
+		ctc21101_phy_setup(phydev, port);
+	}
+	else
+		mii_phy_setup(phydev, port);
+
+	return 0;
+}
+
+static void mv88e6185_fixed_port_setup(struct phy_device *phydev, u8 port)
+{
+	u16 val;
+	u16 ctl = 0;
+
+	val = mv88e6185_port_read(phydev, port, MV88E6185_PORT_STS);
+
+	val &= ~(MV88E6185_PORT_STS_PHY_DETECT);
+	mv88e6185_port_write(phydev, port, MV88E6185_PORT_STS, val);
+
+	ctl |= MV88E6185_PORT_MAC_CTL_LINK_UP | MV88E6185_PORT_MAC_CTL_FORCE_LINK |
+		 MV88E6185_PORT_MAC_CTL_DUPLEX_FULL | MV88E6185_PORT_MAC_CTL_FORCE_DUPLEX |
+		 MV88E6185_PORT_MAC_CTL_SPEED_1000;
+	mv88e6185_port_write(phydev, port, MV88E6185_PORT_MAC_CTL, ctl);
+}
+
+static int mv88e6185_hw_reset(struct phy_device *phydev)
+{
+	int ret;
+	struct gpio_desc gpio;
+	u32 reset_gpio;
+	int node = phydev->addr;
+
+	ret = gpio_request_by_name_nodev(offset_to_ofnode(node),
+		  "reset-gpios", 0, &gpio, GPIOD_IS_OUT | GPIOD_IS_OUT_ACTIVE);
+	if (ret) {
+		printf("%s: unable to reset switch device", __func__);
+		return ret;
+	}
+
+	reset_gpio = PMIO_NODE_ID_BASE + gpio.offset;
+
+	/* Request for pin */
+	xilinx_pm_request(PM_PINCTRL_REQUEST, reset_gpio, 0, 0, 0, NULL);
+
+	/* Enable hysteresis in cmos receiver */
+	xilinx_pm_request(PM_PINCTRL_CONFIG_PARAM_SET, reset_gpio,
+			  PM_PINCTRL_CONFIG_SCHMITT_CMOS,
+			  PM_PINCTRL_INPUT_TYPE_SCHMITT, 0, NULL);
+
+	/* Disable Tri-state */
+	xilinx_pm_request(PM_PINCTRL_CONFIG_PARAM_SET, reset_gpio,
+			  PM_PINCTRL_CONFIG_TRI_STATE,
+			  PM_PINCTRL_TRI_STATE_DISABLE, 0, NULL);
+	udelay(1);
+
+	/* Set value 0 to pin */
+	dm_gpio_set_value(&gpio, 0);
+	mdelay(20);
+
+	/* Set value 1 to pin */
+	dm_gpio_set_value(&gpio, 1);
+	mdelay(300);
+	return 0;
+}
+
+int switchphy_probe(struct phy_device *phydev)
+{
+	int i, ret = 0;
+	u32 fixed, phy;
+	struct fixed_link *priv;
+	int ofnode = phydev->addr;
+	unsigned int prod_num;
+
+	priv = malloc(sizeof(*priv));
+	if (!priv)
+		return -ENOMEM;
+	memset(priv, 0, sizeof(*priv));
+
+	phydev->priv = priv;
+	priv->link_speed = SPEED_1000;
+	priv->duplex = DUPLEX_FULL;
+	priv->pause = false;
+	priv->asym_pause = false;
+
+	/* not be reset by core phy code */
+	phydev->flags |= PHY_FLAG_BROKEN_RESET;
+
+	if (mv88e6185_hw_reset(phydev) != 0) {
+		printf("Error on mv88e6185_hw_reset!\n");
+		return -EINVAL;
+	}
+
+	fixed = fdt_getprop_u32_default_node(gd->fdt_blob,
+					   ofnode, 0, "fixed-ports", 0);
+
+	phy = fdt_getprop_u32_default_node(gd->fdt_blob,
+					   ofnode, 0, "phy-ports", 0);
+	if (fixed > 0x1fff || phy > 0x1fff)
+		return -EINVAL;
+
+	ret = mv88e6185_port_read(phydev, 0, MV88E6185_PORT_SWITCH_ID);
+	prod_num = ret & MV88E6185_PORT_SWITCH_ID_PROD_MASK;
+
+	if (prod_num != MV88E6185_PORT_SWITCH_ID_PROD_6185) {
+		printf("Warning: No switch chip!\n");
+		return -EINVAL;
+	}
+
+	for (i = 0; i < MV88E6185_NUM_PORTS; i++) {
+		if ((1 << i) & fixed)
+			mv88e6185_fixed_port_setup(phydev, i);
+
+		if ((1 << i) & phy)
+			mv88e6185_phy_port_setup(phydev, i);
+	}
+
+	return 0;
+}
+
+int switchphy_startup(struct phy_device *phydev)
+{
+	struct fixed_link *priv = phydev->priv;
+
+	phydev->asym_pause = priv->asym_pause;
+	phydev->pause = priv->pause;
+	phydev->duplex = priv->duplex;
+	phydev->speed = priv->link_speed;
+	phydev->link = 1;
+
+	return 0;
+}
+
+int switchphy_shutdown(struct phy_device *phydev)
+{
+	return 0;
+}
+
+static struct phy_driver switchphy_driver = {
+	.uid		= PHY_SWITCH_ID,
+	.mask		= 0xffffffff,
+	.name		= "SWITCH PHY",
+	.features	= PHY_GBIT_FEATURES | SUPPORTED_MII,
+	.probe		= switchphy_probe,
+	.startup	= switchphy_startup,
+	.shutdown	= switchphy_shutdown,
+};
+
+int phy_switch_init(void)
+{
+	phy_register(&switchphy_driver);
+	return 0;
+}
