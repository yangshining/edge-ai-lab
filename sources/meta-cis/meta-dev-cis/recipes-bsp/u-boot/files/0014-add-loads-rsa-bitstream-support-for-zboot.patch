From 36e3adcb3abd50163474376805ccf1590ebd9f17 Mon Sep 17 00:00:00 2001
From: hexi <xi.he@zillnk.com>
Date: Tue, 13 Sep 2022 14:49:38 +0800
Subject: [PATCH 1/1] u-boot-xlnx: add loads rsa bitstream support for zboot,
 add rsa status dump cmd

Change-Id: I24a9e17e4059d44bf91f8a6a4d226c2cc3f64b60
---
 board/xilinx/zynqmp/zynqmp.c | 14 ++++++++++++++
 cmd/Kconfig                  | 11 +++++++++++
 cmd/Makefile                 |  1 +
 cmd/rsa.c                    | 28 +++++++++++++++++++++++++++
 cmd/zboot.c                  | 37 ++++++++++++++++++++++++++++++++++++
 5 files changed, 91 insertions(+)
 create mode 100755 cmd/rsa.c

diff --git a/board/xilinx/zynqmp/zynqmp.c b/board/xilinx/zynqmp/zynqmp.c
index 7a262385..d8953818 100644
--- a/board/xilinx/zynqmp/zynqmp.c
+++ b/board/xilinx/zynqmp/zynqmp.c
@@ -488,6 +488,18 @@ static u8 __maybe_unused zynqmp_get_bootmode(void)
 	return bootmode;
 }
 
+static u8 __maybe_unused zynqmp_get_rsa_status(void)
+{
+#ifdef CONFIG_ZBOOT_RSA_BITSTREAM
+	puts("RSA STATUS:  ON\n");
+	env_set("rsa", "on");
+#else
+	puts("RSA STATUS:  OFF\n");
+	env_set("rsa", "off");
+#endif
+	return 0;
+}
+
 #if defined(CONFIG_BOARD_LATE_INIT)
 static const struct {
 	u32 bit;
@@ -663,6 +675,8 @@ int board_late_init(void)
 		env_set_hex("bootseq", bootseq);
 	}
 
+	zynqmp_get_rsa_status();
+
 	reset_reason();
 
 	return board_late_init_xilinx();
diff --git a/cmd/Kconfig b/cmd/Kconfig
index a6074c7c..33ebfa6a 100644
--- a/cmd/Kconfig
+++ b/cmd/Kconfig
@@ -139,6 +139,11 @@ config CMD_REGINFO
 	help
 	  Register dump
 
+config CMD_RSA_STATUS
+	bool "rsainfo"
+	help
+	  Rsa status dump
+
 config CMD_TLV_EEPROM
 	bool "tlv_eeprom"
 	depends on I2C_EEPROM
@@ -771,6 +776,12 @@ config CLU_INIT
 	depends on CMD_ZBOOT_Z
 	help
 	  The CLU c is configured through spi
+config ZBOOT_RSA_BITSTREAM
+	bool "loads rsa bit"
+	depends on CMD_ZBOOT_Z
+	help
+	  Loads rsa bit stream to fpga
+
 endmenu
 
 menu "Device access commands"
diff --git a/cmd/Makefile b/cmd/Makefile
index 02f802e9..1b93416c 100644
--- a/cmd/Makefile
+++ b/cmd/Makefile
@@ -130,6 +130,7 @@ obj-$(CONFIG_CMD_REMOTEPROC) += remoteproc.o
 obj-$(CONFIG_CMD_RNG) += rng.o
 obj-$(CONFIG_CMD_ROCKUSB) += rockusb.o
 obj-$(CONFIG_CMD_RTC) += rtc.o
+obj-$(CONFIG_CMD_RSA_STATUS) += rsa.o
 obj-$(CONFIG_SANDBOX) += host.o
 obj-$(CONFIG_CMD_SATA) += sata.o
 obj-$(CONFIG_CMD_NVME) += nvme.o
diff --git a/cmd/rsa.c b/cmd/rsa.c
new file mode 100755
index 00000000..9df6b92d
--- /dev/null
+++ b/cmd/rsa.c
@@ -0,0 +1,28 @@
+/*
+ * Get zboot rsa status
+ *
+ * Copyright (c) 2022 xi.he@zillnk.com.
+ *
+ * Licensed under the GPL-2 or later.
+ */
+
+#include <common.h>
+#include <command.h>
+#include <linux/compiler.h>
+
+static int do_rsa(struct cmd_tbl *cmdtp, int flag, int argc,
+		   char *const argv[])
+{
+#ifdef CONFIG_ZBOOT_RSA_BITSTREAM
+	printf("RSA STATUS:  ON\n");
+#else
+	printf("RSA STATUS:  OFF\n");
+#endif
+	return 0;
+}
+
+U_BOOT_CMD(
+	rsa,	2,		2,	do_rsa,
+	"Get rsa status\n",
+	""
+);
diff --git a/cmd/zboot.c b/cmd/zboot.c
index bc5a17d8..7fc87b14 100644
--- a/cmd/zboot.c
+++ b/cmd/zboot.c
@@ -162,6 +162,39 @@ static long get_fpga_device(char *arg)
 	return dev;
 }
 
+static int do_fpga_loads_rsa_bitstream(int devnum, uint32_t fpga_data, uint32_t data_size)
+{
+	struct fpga_secure_info fpga_sec_info;
+
+	memset(&fpga_sec_info, 0, sizeof(fpga_sec_info));
+	/*
+	*	auth_loc :
+	*
+	*	location of image to be authenticated is located
+	*
+	*	0 = On-Chip Memory (OCM)
+	*
+	*	1 = DDR
+	*
+	*	2 = no authentication
+	*/
+	fpga_sec_info.authflag = 1; //DDR
+	/*
+	* enc_key_sel :
+	*
+	* selection of the encryption key
+	*
+	* 0 = device key
+	*
+	* 1 = user key - KUP
+	*
+	* 2 = no encryption
+	*/
+	fpga_sec_info.encflag = 2;
+	printf("fpga load rsa bitstream.\n");
+	return fpga_loads(devnum, (void *)fpga_data, data_size, &fpga_sec_info);
+}
+
 static int do_fpga_loadb(uint32_t fpgadata, uint32_t datasize)
 {
 	long dev;
@@ -173,7 +206,11 @@ static int do_fpga_loadb(uint32_t fpgadata, uint32_t datasize)
 		return -1;
 	}
 
+#ifdef CONFIG_ZBOOT_RSA_BITSTREAM
+	return do_fpga_loads_rsa_bitstream(dev, fpgadata, datasize);
+#else
 	return fpga_loadbitstream(dev, (void *)fpgadata, datasize, BIT_FULL);
+#endif
 }
 
 static int parse_head_data(uint32_t base_addr)
-- 
2.31.1

