+/******************************************************************************
+*
+* Static API used for Gigadevice flash to enable or disable QPI mode
+*
+* @param	QspiPsuPtr Pointer to QSPI instance.
+* @param    Enable valid values are 0 (disable) and 1 (enable).
+*
+* @return	XFSBL_SUCCESS if success, otherwise XFSBL_ERROR_QSPI_READ.
+*
+* @note		None.
+*
+******************************************************************************/
+static u32 GigadeviceEnableQPIMode(XQspiPsu *QspiPsuPtr, int Enable)
+{
+	s32 Status;
+	u32 UStatus;
+	u8 ReadStatusCmd;
+	u8 FlashStatus[2];
+	u8 StatusRegVal;
+
+	/* Read the value of status register no.2*/
+	ReadStatusCmd = READ_STATUS_REG_2_CMD;
+	FlashMsg[0].TxBfrPtr = &ReadStatusCmd;
+	FlashMsg[0].RxBfrPtr = NULL;
+	FlashMsg[0].ByteCount = 1;
+	if (Enable == ENABLE_QPI) {
+		FlashMsg[0].BusWidth = XQSPIPSU_SELECT_MODE_SPI;
+	} else {
+		FlashMsg[0].BusWidth = XQSPIPSU_SELECT_MODE_QUADSPI;
+	}
+
+	FlashMsg[0].Flags = XQSPIPSU_MSG_FLAG_TX;
+	FlashMsg[1].TxBfrPtr = NULL;
+	FlashMsg[1].RxBfrPtr = FlashStatus;
+	FlashMsg[1].ByteCount = 2;
+	if (Enable == ENABLE_QPI) {
+		FlashMsg[1].BusWidth = XQSPIPSU_SELECT_MODE_SPI;
+	} else {
+		FlashMsg[1].BusWidth = XQSPIPSU_SELECT_MODE_QUADSPI;
+	}
+	FlashMsg[1].Flags = XQSPIPSU_MSG_FLAG_RX;
+	
+	Status = XQspiPsu_PolledTransfer(QspiPsuPtr, FlashMsg, 2);
+	if (Status != XST_SUCCESS) {
+		UStatus = XFSBL_ERROR_QSPI_READ;
+		XFsbl_Printf(DEBUG_GENERAL,"XFSBL_ERROR_QSPI_READ\r\n");
+		goto END;
+
+	}
+	
+	if (QspiPsuPtr->Config.ConnectionMode ==
+		XQSPIPSU_CONNECTION_MODE_PARALLEL) {
+		FlashStatus[1] |= FlashStatus[0];
+	}
+	/*
+	 * Set Quad Enable Bit in the buffer
+	 */
+	StatusRegVal = FlashStatus[1];
+	XFsbl_Printf(DEBUG_GENERAL,"Old status register no.2:0x%02x\r\n", StatusRegVal);
+
+	/*Enable register write*/
+	TxBfrPtr = WRITE_ENABLE_CMD;
+	FlashMsg[0].TxBfrPtr = &TxBfrPtr;
+	FlashMsg[0].RxBfrPtr = NULL;
+	FlashMsg[0].ByteCount = 1;
+	if (Enable == ENABLE_QPI) {
+		FlashMsg[0].BusWidth = XQSPIPSU_SELECT_MODE_SPI;
+	} else {
+		FlashMsg[0].BusWidth = XQSPIPSU_SELECT_MODE_QUADSPI;
+	}
+	FlashMsg[0].Flags = XQSPIPSU_MSG_FLAG_TX;
+
+	Status = XQspiPsu_PolledTransfer(&QspiPsuInstance, &FlashMsg[0], 1);
+	if (Status != XFSBL_SUCCESS) {
+		UStatus = XFSBL_ERROR_QSPI_READ;
+		XFsbl_Printf(DEBUG_GENERAL,"XFSBL_ERROR_QSPI_READ\r\n");
+		goto END;
+	}
+
+	if (Enable == ENABLE_QPI)
+		StatusRegVal |= 0x1 << GD_QUAD_MODE_ENABLE_BIT;
+	else
+		StatusRegVal &= ~(0x1 << GD_QUAD_MODE_ENABLE_BIT);
+
+	XFsbl_Printf(DEBUG_GENERAL,"new status register no.2:0x%02x\r\n", StatusRegVal);
+
+	/*
+	 * Write Status register
+	 */
+	WriteBuffer[COMMAND_OFFSET] = WRITE_STATUS_REG_2_CMD;
+	FlashMsg[0].TxBfrPtr = WriteBuffer;
+	FlashMsg[0].RxBfrPtr = NULL;
+	FlashMsg[0].ByteCount = 1;
+	if (Enable == ENABLE_QPI) {
+		FlashMsg[0].BusWidth = XQSPIPSU_SELECT_MODE_SPI;
+	} else {
+		FlashMsg[0].BusWidth = XQSPIPSU_SELECT_MODE_QUADSPI;
+	}
+
+	FlashMsg[0].Flags = XQSPIPSU_MSG_FLAG_TX;
+	
+	FlashMsg[1].TxBfrPtr = &StatusRegVal;
+	FlashMsg[1].RxBfrPtr = NULL;
+	FlashMsg[1].ByteCount = 1;
+	if (Enable == ENABLE_QPI) {
+		FlashMsg[1].BusWidth = XQSPIPSU_SELECT_MODE_SPI;
+	} else {
+		FlashMsg[1].BusWidth = XQSPIPSU_SELECT_MODE_QUADSPI;
+	}
+
+	FlashMsg[1].Flags = XQSPIPSU_MSG_FLAG_TX;
+	
+	Status = XQspiPsu_PolledTransfer(QspiPsuPtr, FlashMsg, 2);
+	if (Status != XST_SUCCESS) {
+		UStatus = XFSBL_ERROR_QSPI_READ;
+		XFsbl_Printf(DEBUG_GENERAL,"XFSBL_ERROR_QSPI_READ\r\n");
+		goto END;
+
+	}
+
+	UStatus = XFSBL_SUCCESS;
+
+END:
+	return UStatus;
+}
