diff --git a/drivers/misc/rmdom.c b/drivers/misc/rmdom.c
new file mode 100644
index 000000000..ee28f6788
--- /dev/null
+++ b/drivers/misc/rmdom.c
@@ -0,0 +1,448 @@
+/*
+ * Remaining Memory Domains Header
+ * 
+ * set a separate domain/region into fs for log system after system reboot
+ */
+
+#include <linux/platform_device.h>
+#include <linux/io.h>
+#include <linux/module.h>
+
+#include <linux/pstore_ram.h>
+#include <linux/slab.h>
+
+#include <linux/of.h>
+#include <linux/of_address.h>
+
+#include <linux/crc32.h>
+#include "rmdom.h"
+
+// create rmdom unique ids
+DEFINE_IDA(rmdom_uni_ida);
+static const struct of_device_id rmdom_ids[] = {
+    { .compatible = "linux,rmdom", }, { },
+};
+
+// Init a resource for pmem from DT
+static void populate_part_res(const struct rmdom_dev *rmddev, const struct rmdom_part *part, const char *name, struct resource *res)
+{
+    res->name = name;
+    res->flags = IORESOURCE_MEM;
+    res->start = rmddev->start + part->start;
+    res->end = res->start + part->size - 1;
+    res->parent = res->sibling =  res->child = NULL;
+}
+
+// set ramoops private data by DT
+static void populate_oops_pl_data(const struct rmdom_dev *rmddev, const struct rmdom_part *part, struct ramoops_platform_data *pdata)
+{
+    const struct rmdom_ramoops *params = &part->params.ramoops;
+
+    pdata->mem_size     = part->size;
+    pdata->mem_type     = params->mem_type;
+    pdata->mem_address  = rmddev->start + part->start;
+    pdata->record_size  = params->record_size;
+    pdata->console_size = params->console_size;
+    pdata->pmsg_size    = params->rmsg_size;
+    pdata->ftrace_size  = params->ftrace_size;
+    pdata->ecc_info.ecc_size = (params->ecc_size == 1 ? 16 : params->ecc_size);
+    pdata->max_reason = KMSG_DUMP_OOPS;
+}
+
+// Helper function to read a size from a dtb
+static u32 read_size_data(const struct device_node *node, const char *name)
+{
+    u32 val = 0;
+    int ret;
+
+    ret = of_property_read_u32(node, name, &val);
+    if (ret < 0 && ret != -EINVAL) {
+        pr_err("Parse meta-data failed - %s: %d\n", name, ret);
+        return -1;
+    }
+    return val;
+}
+
+static void printout_hdr(struct rmdom_header *cfg_rh)
+{
+    struct rmdom_header *rh = cfg_rh;
+    struct rmdom_part *part = &rh->parts[0];
+    int i;
+    printk("printout_hdr started - [mg:%x, v:%x.%x]\n", rh->magic, rh->major, rh->minor);
+    printk("printout_hdr checksum - [checksum:%x]\n", rh->cs);
+    for ( i = 0; i < 3; i++ )
+    {
+        printk("\tPart%x -- [categ:%x]\n", i, part->categ);
+        printk("\t ---- [part_sub_version:%x.%x]\n", part->major, part->minor);
+        printk("\t ---- [mem-reg:0x%x - 0x%x]\n", part->start, part->size);
+        part++;
+    }
+}
+
+static int register_nvdimm_bus(struct rmdom_dev *rmddev, struct device_node *dn)
+{
+    int ret = 0;
+    dn = dev_of_node(rmddev->dev);
+    if (!dn) {
+        dev_err(rmddev->dev, "Node pointer empty\n");
+        ret = -ENODEV;
+        goto end;
+    }
+
+    rmddev->bus_desc.provider_name = "rmdom_rmem";
+    rmddev->bus_desc.module = THIS_MODULE;
+    rmddev->bus_desc.of_node = dn;
+
+    rmddev->bus = nvdimm_bus_register(rmddev->dev, &rmddev->bus_desc);
+    if (!rmddev->bus) {
+        dev_err(rmddev->dev, "Can't register nvdimm bus\n");
+        ret = -ENODEV;
+        goto end;
+    }
+end:
+    return ret;
+}
+
+// Register devices as pointed by current header
+static void register_subdevices(struct rmdom_dev *rmddev)
+{
+    const struct rmdom_header *hdr = &rmddev->curr;
+    int i;
+    struct device_node *dnp;
+
+    //dev_info(rmddev->dev, "####reg subdevices config dump:\n");
+    //printout_hdr(hdr);
+    if(register_nvdimm_bus(rmddev, dnp)) {
+        dev_warn(rmddev->dev, "Failed to register nvdimm bus\n");
+        return;
+    }
+
+    // Register all known platform devices pointed by the header
+    dev_info(rmddev->dev, "current subdevices num %x\n", ARRAY_SIZE(hdr->parts)); 
+    for (i = 0; i < ARRAY_SIZE(hdr->parts); i++) {
+        const struct rmdom_part *part = &hdr->parts[i];
+        switch (part->categ) {
+        case RMDOM_CATEG_EMPTY:
+            break;
+        case RMDOM_CATEG_RMEM:
+        {
+            struct resource res;
+            struct nd_region_desc desc;
+            struct nd_region *region;
+
+            if (part->major != RMDOM_RMEM_MAJOR) {
+                dev_info(rmddev->dev, "Query DT to get major version %d but expected %d for rmem in part %d\n", part->major, RMDOM_RMEM_MAJOR, i);
+                continue;
+            }
+
+            populate_part_res(rmddev, part, "rmdom_rmem", &res);
+            dev_dbg(rmddev->dev, "rmem in slot %d in %p\n", i, &res);
+
+            memset(&desc, 0, sizeof(desc));
+            desc.numa_node = dev_to_node(rmddev->dev);
+            desc.res = &res;
+            desc.of_node = dnp;
+            set_bit(ND_REGION_PAGEMAP, &desc.flags);
+
+            region = nvdimm_pmem_region_create(rmddev->bus, &desc);
+
+            if (!region)
+                dev_warn(rmddev->dev, "Can't register region %p with %p\n", desc.res, dnp);
+            else
+                dev_dbg(rmddev->dev, "Registered region %p with %p\n", desc.res, dnp);
+            dev_info(rmddev->dev, "Register rmem device\n");
+            break;
+        }
+        case RMDOM_CATEG_RAMOOPS:
+        {
+            struct ramoops_platform_data pldata;
+            struct resource res;
+
+            if (!rmddev->pstore)
+                continue;
+
+            if (part->major != RMDOM_RAMOOPS_MAJOR) {
+                dev_info(rmddev->dev, "Query DT to get major version %d but expected %d for ramoops in part %d\n", part->major, RMDOM_RAMOOPS_MAJOR, i);
+                continue;
+            }
+            populate_oops_pl_data(rmddev, part, &pldata);
+
+            res.start = pldata.mem_address;
+            res.end = res.start + pldata.mem_size + 1;
+            dev_dbg(rmddev->dev, "ramoops in slot %d %pR\n", i, &res);
+
+            rmddev->pdevs[i] = platform_device_register_data(NULL, "ramoops", -1, &pldata, sizeof(pldata));
+            if (IS_ERR(rmddev->pdevs[i])) {
+                dev_warn(rmddev->dev, "Failed to register ramoops device in part %d with err=%ld\n", i, PTR_ERR(rmddev->pdevs[i]));
+            }
+            dev_info(rmddev->dev, "Register ramoops device\n");            
+            break;
+        }
+        default:
+            dev_warn(rmddev->dev, "Unexpected part %d\n", part->categ);
+            break;
+        }
+    }
+}
+
+// Deregister the subdevices registered
+static int deregister_subdevices(struct rmdom_dev *rmddev)
+{
+    int i;
+
+    if (rmddev->bus) {
+        nvdimm_bus_unregister(rmddev->bus);
+        rmddev->bus = NULL;
+    }
+
+    for (i = 0; i < RMDOM_PART_NUM; i++) {
+        struct platform_device *pdev = rmddev->pdevs[i];
+
+        if (!IS_ERR(pdev)) {
+            platform_device_unregister(pdev);
+        }
+        rmddev->pdevs[i] = NULL;
+    }
+    return 0;
+}
+
+//populate header with DT info
+static int populate_hdr(struct rmdom_header *cfg_rh, struct platform_device *pdev)
+{
+    int ret = 0;
+    struct rmdom_header *rh = cfg_rh;
+    struct rmdom_dev *rmddev = platform_get_drvdata(pdev);
+    struct rmdom_part *part = &rh->parts[0];
+    const struct device_node *of_node = pdev->dev.of_node;
+    struct device_node *subnode;
+
+    rmddev->pstore = false;
+    rh->magic = RMDOM_MAGIC;
+    rh->minor = RMDOM_MINOR;
+    rh->major = RMDOM_MAJOR;
+
+    for_each_child_of_node(of_node, subnode) {
+        struct resource res;
+        if (of_address_to_resource(subnode, 0, &res)) {
+            dev_warn(&pdev->dev, "Can't get resource for subnode %s\n", subnode->full_name);
+            continue;
+        }
+        part->start = res.start;
+        part->size = resource_size(&res);
+        dev_info(&pdev->dev, "Detect a part range: 0x%x : 0x%x\n", part->start, part->size);
+        if (of_device_is_compatible(subnode, "linux,rmdom-rmem")) {
+            part->categ = RMDOM_CATEG_RMEM;
+            part->major = RMDOM_RMEM_MAJOR;
+            part->minor = RMDOM_RMEM_MINOR;
+            part++;
+            dev_info(&pdev->dev, "A regular part\n");
+        } else if (of_device_is_compatible(subnode, "linux,rmdom-ramoops")) {
+            struct rmdom_ramoops *p = &part->params.ramoops;
+
+            part->categ = RMDOM_CATEG_RAMOOPS;
+            part->major = RMDOM_RAMOOPS_MAJOR;
+            part->minor = RMDOM_RAMOOPS_MINOR;
+
+            p->mem_type = of_property_read_bool(subnode, "unbuffered");
+            p->dump_oops = !of_property_read_bool(subnode, "no-dump-oops");
+
+            p->record_size = read_size_data(subnode, "record-size");
+            p->console_size = read_size_data(subnode, "console-size");
+            p->ftrace_size = read_size_data(subnode, "ftrace-size");
+            p->rmsg_size = read_size_data(subnode, "rmsg-size");
+            p->ecc_size = read_size_data(subnode, "ecc-size");
+            p->flags = read_size_data(subnode, "flags");
+            rmddev->pstore = true;
+            part++;
+            dev_info(&pdev->dev, "A ramoops part to enable pstore\n");
+        } else {
+            dev_warn(&pdev->dev, "Unexpected subnode node: %s\n", subnode->full_name);
+        }
+    }
+
+    rh->cs = crc32(0, rh, sizeof(struct rmdom_header));
+    return ret;
+}
+
+//alignment size to 1024bytes
+static void header_def_sanity_check(void)
+{
+    // check header's with the correct size
+    BUILD_BUG_ON(sizeof(struct rmdom_header) != RMDOM_HDR_SIZE);
+    BUILD_BUG_ON(sizeof(struct rmdom_part) != RMDOM_HDR_REGION_PADDING_SIZE);
+    BUILD_BUG_ON(offsetof(struct rmdom_header, parts) != RMDOM_HDR_REGION_PADDING_SIZE);
+}
+
+//get reserved memory range and mmap
+static int rmdom_memmap(struct platform_device *pdev)
+{
+    struct device_node *memdom;
+    struct device_node *of_node = pdev->dev.of_node;
+    struct rmdom_dev *rmddev = platform_get_drvdata(pdev);
+    struct resource res;
+    int ret = 0;
+    /* Map the persistent memory and copy out the header*/
+    memdom = of_parse_phandle(of_node, "memory-domain", 0);
+    if (!memdom) {
+        dev_err(&pdev->dev, "Not set memory-domain: %s\n", of_node->full_name);
+        ret = -ENODEV;
+        goto end;
+    }
+    ret = of_address_to_resource(memdom, 0, &res);
+    if (ret) {
+        dev_err(&pdev->dev, "Memory resource incorrect: %s\n", memdom->full_name);
+        goto end;
+    }
+
+    rmddev->start = res.start;
+    rmddev->size = resource_size(&res);
+    rmddev->virt = ioremap(rmddev->start, rmddev->size);
+    dev_info(&pdev->dev, "Reserved memory region range: 0x%x : 0x%x - virt %x\n", 
+        rmddev->start, rmddev->size, rmddev->virt);
+    if (!rmddev->virt) {
+        ret = -ENOMEM;
+        goto end;
+    }
+end:    
+    return ret;
+}
+
+static int rmdom_remove(struct platform_device *pdev)
+{
+    int ret;
+    struct rmdom_dev *rmddev = platform_get_drvdata(pdev);
+
+    dev_info(&pdev->dev, "rmdom_remove called\n");
+    ret = deregister_subdevices(rmddev);
+    if (ret)
+        return ret;
+
+    //rmdom_release_sysfs(rmddev);
+    iounmap(rmddev->virt);
+    kfree(rmddev);
+    dev_info(&pdev->dev, "rmdom_remove exit\n");
+    ret = 0;
+    return ret;
+}
+
+static int rmdom_probe(struct platform_device *pdev)
+{
+    struct device_node *of_node = pdev->dev.of_node;
+    struct device_node *memdom;
+    int valid_hdr = 1;
+    int ret = 0;
+    u32 cs;
+    struct rmdom_dev *rmddev;
+    struct rmdom_header *hdr;
+    struct rmdom_header cfg_hdr;
+    struct resource res;
+
+    //set zero for its init
+    memset(&cfg_hdr, 0, sizeof(cfg_hdr));
+    dev_info(&pdev->dev, "rmdom_probe called\n");
+    rmddev = kzalloc(sizeof(*rmddev), GFP_KERNEL);
+    if (!rmddev)  {
+        ret = -ENOMEM;
+        dev_info(&pdev->dev, "rmdom kzalloc failed\n");
+        return ret;
+    }
+
+    header_def_sanity_check();
+
+    rmddev->id = ida_simple_get(&rmdom_uni_ida, 0, 0, GFP_KERNEL);
+    rmddev->dev = &pdev->dev;
+    dev_info(&pdev->dev, "Get ida id %d\n", rmddev->id);
+    if (rmddev->id < 0)
+        goto err_free_dev;
+    
+    // attach private data to platform device
+    platform_set_drvdata(pdev, rmddev);
+    // Init the defaulted header with DT info
+    (void) populate_hdr(&cfg_hdr, pdev);
+    //dev_info(&pdev->dev, "####local data config dump:\n");
+    //printout_hdr(&cfg_hdr);
+    //get memory range from DT
+    if(rmdom_memmap(pdev)) {
+        goto err_free;
+    }
+
+    // Init the current header
+    hdr = &rmddev->curr;
+
+    // Read out current reserved region header
+    memcpy(hdr, rmddev->virt, sizeof(struct rmdom_header));
+    //dev_info(&pdev->dev, "@@@current RAM read-back config dump:\n");
+    //printout_hdr(hdr);
+    // compare the header info from RAM with the one by default
+    cs = hdr->cs;
+    hdr->cs = 0;
+
+    if (hdr->magic != RMDOM_MAGIC) {
+        dev_info(&pdev->dev, "No RMDOM header magic\n");
+        valid_hdr = 0;
+    } else if (cs != crc32(0, hdr, sizeof(struct rmdom_header))) {
+        dev_info(&pdev->dev, "Incorrect checksum [0x%x != 0x%x]\n", cs, crc32(0, hdr, sizeof(struct rmdom_header)));
+        valid_hdr = 0;
+    }
+    // set value back
+    hdr->cs = cs;
+
+
+    if (valid_hdr)
+        dev_info(&pdev->dev, "Detected correct RMDOM header with version %d.%d\n", hdr->major, hdr->minor);
+
+    // No correct header, create a default one from DT
+    if (!valid_hdr) {
+        memcpy(&rmddev->curr, &cfg_hdr, sizeof(rmddev->curr));
+        dev_info(&pdev->dev, "Using meta-data config from DT -- version %d.%d\n", hdr->major, hdr->minor);
+    }
+    //dev_info(&pdev->dev, "####current segment config dump:\n");
+    //printout_hdr(&rmddev->curr);
+
+    if (hdr->major != RMDOM_MAJOR) {
+        dev_err(&pdev->dev, "Found major version %d but expected %d for main header\n", hdr->major, RMDOM_MAJOR);
+    } else {
+        memcpy(rmddev->virt, &rmddev->curr, sizeof(rmddev->curr));
+        dev_info(&pdev->dev, "Set back to the header inside RAM.\n");
+        dev_info(&pdev->dev, "####virt segment config dump:\n");
+        printout_hdr((struct rmdom_header*)rmddev->virt); 
+        register_subdevices(rmddev);
+    }
+
+    dev_info(&pdev->dev, "rmdom_probe exit - no sysfs\n");
+    return 0;
+
+ err_free:
+    ida_simple_remove(&rmdom_uni_ida, rmddev->id);
+ err_free_dev:
+    kfree(rmddev);
+ err:
+    return ret;
+}
+
+MODULE_DEVICE_TABLE(of, rmdom_ids);
+static struct platform_driver rmdom_pl_drv = {
+    .remove = rmdom_remove,    
+    .probe = rmdom_probe,
+    .driver = {
+        .of_match_table = rmdom_ids,
+        .name   = "rmdom",
+        .owner  = THIS_MODULE,
+    }
+};
+
+static void __exit rmdom_exit(void)
+{
+    platform_driver_unregister(&rmdom_pl_drv);
+}
+
+static int __init rmdom_init(void)
+{
+    return platform_driver_register(&rmdom_pl_drv);
+}
+
+module_exit(rmdom_exit);
+fs_initcall(rmdom_init);
+
+MODULE_LICENSE("GPL");
+MODULE_AUTHOR("null.com");
diff --git a/drivers/misc/rmdom.h b/drivers/misc/rmdom.h
new file mode 100644
index 000000000..35152dff1
--- /dev/null
+++ b/drivers/misc/rmdom.h
@@ -0,0 +1,81 @@
+/*
+ * Remaining Memory Domains Header
+ * 
+ * set a separate domain/region for log system/racd after system warm reboot
+ */
+#ifndef _RM_DOM_H_
+#define _RM_DOM_H_
+
+#include <linux/types.h>
+
+#include <linux/libnvdimm.h>
+
+// set magic field
+#define RMDOM_MAGIC 0xCA693737
+
+// header's major and minor version
+#define RMDOM_MAJOR 1
+#define RMDOM_MINOR 1
+
+// Remaining memory domain category definition
+#define RMDOM_CATEG_EMPTY    0
+#define RMDOM_CATEG_RMEM     1
+#define RMDOM_CATEG_RAMOOPS  2
+
+#define RMDOM_RMEM_MAJOR    1
+#define RMDOM_RMEM_MINOR    1
+struct rmdom_rmem {};
+
+#define RMDOM_RAMOOPS_MAJOR 1
+#define RMDOM_RAMOOPS_MINOR 1
+struct rmdom_ramoops {
+    u8 mem_type;
+    u8 dump_oops;
+    u8 reserved[2];
+    u32 record_size;
+    u32 console_size;
+    u32 ftrace_size;
+    u32 rmsg_size;
+    u32 ecc_size;
+    u32 flags;
+};
+
+#define RMDOM_HDR_SIZE 1024
+#define RMDOM_HDR_REGION_PADDING_SIZE 128
+#define RMDOM_PART_NUM  7
+
+// the header placed into the 1KB at the begining of RMDOM reserved memory
+struct rmdom_header {
+    u32 magic;
+    u16 major;
+    u16 minor;
+    u32 cs; //its CRC32 checksum value
+    u8 padding1[RMDOM_HDR_REGION_PADDING_SIZE - 3 * sizeof(u32)];
+    struct rmdom_part {
+        u32 categ;//one of category for rmemory management
+        u16 major;
+        u16 minor;
+        u64 start;
+        u64 size;
+        union {
+            u8 padding2[RMDOM_HDR_REGION_PADDING_SIZE - 2 * sizeof(u32) - 2 * sizeof(u64)];
+            struct rmdom_ramoops ramoops;
+            struct rmdom_rmem rmem;
+        } params;
+    } parts[RMDOM_PART_NUM];
+} __packed;
+
+struct rmdom_dev {
+    int id;
+    struct device *dev;
+    phys_addr_t start;
+    resource_size_t size;
+    char *virt;    
+    struct rmdom_header curr; //current configuration for RMDOM
+    struct platform_device *pdevs[RMDOM_PART_NUM];
+    bool pstore;
+    struct nvdimm_bus *bus;
+    struct nvdimm_bus_descriptor bus_desc;
+};
+
+#endif
diff --git a/drivers/misc/rsmu_cdev.c b/drivers/misc/rsmu_cdev.c
new file mode 100644
index 000000000..51a585de7
--- /dev/null
+++ b/drivers/misc/rsmu_cdev.c
@@ -0,0 +1,373 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * This driver is developed for the IDT ClockMatrix(TM) and 82P33xxx families
+ * of timing and synchronization devices. It will be used by Renesas PTP Clock
+ * Manager for Linux (pcm4l) software to provide support to GNSS assisted
+ * partial timing support (APTS) and other networking timing functions.
+ *
+ * Please note it must work with Renesas MFD driver to access device through
+ * I2C/SPI.
+ *
+ * Copyright (C) 2019 Integrated Device Technology, Inc., a Renesas Company.
+ */
+
+#define pr_fmt(fmt) KBUILD_MODNAME ": " fmt
+
+#include <linux/cdev.h>
+#include <linux/device.h>
+#include <linux/fs.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/of.h>
+#include <linux/platform_device.h>
+#include <linux/slab.h>
+#include <linux/uaccess.h>
+#include <linux/mfd/rsmu.h>
+#include <uapi/linux/rsmu.h>
+
+#include "rsmu_cdev.h"
+
+#define DRIVER_NAME	"rsmu"
+#define DRIVER_MAX_DEV	BIT(MINORBITS)
+
+static struct class *rsmu_class;
+static dev_t rsmu_cdevt;
+static struct rsmu_ops *ops_array[] = {
+	[RSMU_CM] = &cm_ops,
+	[RSMU_SABRE] = &sabre_ops,
+};
+
+static int
+rsmu_set_combomode(struct rsmu_cdev *rsmu, void __user *arg)
+{
+	struct rsmu_ops *ops = rsmu->ops;
+	struct rsmu_combomode mode;
+	int err;
+
+	if (copy_from_user(&mode, arg, sizeof(mode)))
+		return -EFAULT;
+
+	if (ops->set_combomode == NULL)
+		return -ENOTSUPP;
+
+	mutex_lock(rsmu->lock);
+	err = ops->set_combomode(rsmu, mode.dpll, mode.mode);
+	mutex_unlock(rsmu->lock);
+
+	return err;
+}
+
+static int
+rsmu_get_dpll_state(struct rsmu_cdev *rsmu, void __user *arg)
+{
+	struct rsmu_ops *ops = rsmu->ops;
+	struct rsmu_get_state state_request;
+	u8 state;
+	int err;
+
+	if (copy_from_user(&state_request, arg, sizeof(state_request)))
+		return -EFAULT;
+
+	if (ops->get_dpll_state == NULL)
+		return -ENOTSUPP;
+
+	mutex_lock(rsmu->lock);
+	err = ops->get_dpll_state(rsmu, state_request.dpll, &state);
+	mutex_unlock(rsmu->lock);
+
+	state_request.state = state;
+	if (copy_to_user(arg, &state_request, sizeof(state_request)))
+		return -EFAULT;
+
+	return err;
+}
+
+static int
+rsmu_get_dpll_ffo(struct rsmu_cdev *rsmu, void __user *arg)
+{
+	struct rsmu_ops *ops = rsmu->ops;
+	struct rsmu_get_ffo ffo_request;
+	int err;
+
+	if (copy_from_user(&ffo_request, arg, sizeof(ffo_request)))
+		return -EFAULT;
+
+	if (ops->get_dpll_ffo == NULL)
+		return -ENOTSUPP;
+
+	mutex_lock(rsmu->lock);
+	err = ops->get_dpll_ffo(rsmu, ffo_request.dpll, &ffo_request);
+	mutex_unlock(rsmu->lock);
+
+	if (copy_to_user(arg, &ffo_request, sizeof(ffo_request)))
+		return -EFAULT;
+
+	return err;
+}
+
+static int
+rsmu_get_regval(struct rsmu_cdev *rsmu, void __user *arg)
+{
+	struct rsmu_ops *ops = rsmu->ops;
+	struct rsmu_regval reg_info;
+	int err;
+
+	if (copy_from_user(&reg_info, arg, sizeof(reg_info)))
+		return -EFAULT;
+
+	if (ops->get_reg_val == NULL)
+		return -ENOTSUPP;
+
+	mutex_lock(rsmu->lock);
+	err = ops->get_reg_val(rsmu, &reg_info);
+	mutex_unlock(rsmu->lock);
+
+	if (copy_to_user(arg, &reg_info, sizeof(reg_info)))
+		return -EFAULT;
+
+	return err;
+}
+
+static int
+rsmu_set_regval(struct rsmu_cdev *rsmu, void __user *arg)
+{
+	struct rsmu_ops *ops = rsmu->ops;
+	struct rsmu_regval reg_info;
+	int err;
+
+	if (copy_from_user(&reg_info, arg, sizeof(reg_info)))
+		return -EFAULT;
+
+	if (ops->set_reg_val == NULL)
+		return -ENOTSUPP;
+
+	mutex_lock(rsmu->lock);
+	err = ops->set_reg_val(rsmu, &reg_info);
+	mutex_unlock(rsmu->lock);
+
+	if (copy_to_user(arg, &reg_info, sizeof(reg_info)))
+		return -EFAULT;
+
+	return err;
+}
+
+static int
+rsmu_open(struct inode *iptr, struct file *fptr)
+{
+	struct rsmu_cdev *rsmu;
+
+	rsmu = container_of(iptr->i_cdev, struct rsmu_cdev, rsmu_cdev);
+	fptr->private_data = rsmu;
+	return 0;
+}
+
+static int
+rsmu_release(struct inode *iptr, struct file *fptr)
+{
+	return 0;
+}
+
+static long
+rsmu_ioctl(struct file *fptr, unsigned int cmd, unsigned long data)
+{
+	struct rsmu_cdev *rsmu = fptr->private_data;
+	void __user *arg = (void __user *)data;
+	int err = 0;
+
+	switch (cmd) {
+	case RSMU_SET_COMBOMODE:
+		err = rsmu_set_combomode(rsmu, arg);
+		break;
+	case RSMU_GET_STATE:
+		err = rsmu_get_dpll_state(rsmu, arg);
+		break;
+	case RSMU_GET_FFO:
+		err = rsmu_get_dpll_ffo(rsmu, arg);
+		break;
+	case RSMU_GET_REGVAL:
+		err = rsmu_get_regval(rsmu, arg);
+		break;
+	case RSMU_SET_REGVAL:
+		err = rsmu_set_regval(rsmu, arg);
+		break;
+	default:
+		/* Should not get here */
+		dev_err(rsmu->dev, "Undefined RSMU IOCTL");
+		err = -EINVAL;
+		break;
+	}
+
+	return err;
+}
+
+static long rsmu_compat_ioctl(struct file *fptr, unsigned int cmd,
+			      unsigned long data)
+{
+	return rsmu_ioctl(fptr, cmd, data);
+}
+
+static const struct file_operations rsmu_fops = {
+	.owner = THIS_MODULE,
+	.open = rsmu_open,
+	.release = rsmu_release,
+	.unlocked_ioctl = rsmu_ioctl,
+	.compat_ioctl =	rsmu_compat_ioctl,
+};
+
+static int rsmu_init_ops(struct rsmu_cdev *rsmu)
+{
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(ops_array); i++)
+		if (ops_array[i]->type == rsmu->type)
+			break;
+
+	if (i == ARRAY_SIZE(ops_array))
+		return -EINVAL;
+
+	rsmu->ops = ops_array[i];
+	return 0;
+}
+
+static int
+rsmu_probe(struct platform_device *pdev)
+{
+	struct rsmu_pdata *pdata = dev_get_platdata(&pdev->dev);
+	struct rsmu_cdev *rsmu;
+	struct device *rsmu_cdev;
+	int err;
+
+	rsmu = devm_kzalloc(&pdev->dev, sizeof(*rsmu), GFP_KERNEL);
+	if (!rsmu)
+		return -ENOMEM;
+
+	rsmu->dev = &pdev->dev;
+	rsmu->mfd = pdev->dev.parent;
+	rsmu->type = pdata->type;
+	rsmu->lock = pdata->lock;
+	rsmu->index = pdata->index;
+
+	/* Save driver private data */
+	platform_set_drvdata(pdev, rsmu);
+
+	cdev_init(&rsmu->rsmu_cdev, &rsmu_fops);
+	rsmu->rsmu_cdev.owner = THIS_MODULE;
+	err = cdev_add(&rsmu->rsmu_cdev,
+		       MKDEV(MAJOR(rsmu_cdevt), 0), 1);
+	if (err < 0) {
+		dev_err(rsmu->dev, "cdev_add failed");
+		err = -EIO;
+		goto err_rsmu_dev;
+	}
+
+	if (!rsmu_class) {
+		err = -EIO;
+		dev_err(rsmu->dev, "rsmu class not created correctly");
+		goto err_rsmu_cdev;
+	}
+
+	rsmu_cdev = device_create(rsmu_class, rsmu->dev,
+				  MKDEV(MAJOR(rsmu_cdevt), 0),
+				  rsmu, "rsmu%d", rsmu->index);
+	if (IS_ERR(rsmu_cdev)) {
+		dev_err(rsmu->dev, "Unable to create char device");
+		err = PTR_ERR(rsmu_cdev);
+		goto err_rsmu_cdev;
+	}
+
+	err = rsmu_init_ops(rsmu);
+	if (err) {
+		dev_err(rsmu->dev, "Unable to match type %d", rsmu->type);
+		goto err_rsmu_cdev;
+	}
+
+	dev_info(rsmu->dev, "Probe SMU type %d successful\n", rsmu->type);
+	return 0;
+
+	/* Failure cleanup */
+err_rsmu_cdev:
+	cdev_del(&rsmu->rsmu_cdev);
+err_rsmu_dev:
+	return err;
+}
+
+static int
+rsmu_remove(struct platform_device *pdev)
+{
+	struct rsmu_cdev *rsmu = platform_get_drvdata(pdev);
+	struct device *dev = &pdev->dev;
+
+	if (!rsmu_class) {
+		dev_err(dev, "rsmu_class is NULL");
+		return -EIO;
+	}
+
+	device_destroy(rsmu_class, MKDEV(MAJOR(rsmu_cdevt), 0));
+	cdev_del(&rsmu->rsmu_cdev);
+
+	return 0;
+}
+
+static const struct platform_device_id rsmu_id_table[] = {
+	{ "rsmu-cdev0", },
+	{ "rsmu-cdev1", },
+	{ "rsmu-cdev2", },
+	{ "rsmu-cdev3", },
+	{}
+};
+MODULE_DEVICE_TABLE(platform, rsmu_id_table);
+
+static struct platform_driver rsmu_driver = {
+	.driver = {
+		.name = DRIVER_NAME,
+	},
+	.probe = rsmu_probe,
+	.remove =  rsmu_remove,
+	.id_table = rsmu_id_table,
+};
+
+static int __init rsmu_init(void)
+{
+	int err;
+
+	rsmu_class = class_create(THIS_MODULE, DRIVER_NAME);
+	if (IS_ERR(rsmu_class)) {
+		err = PTR_ERR(rsmu_class);
+		pr_err("Unable to register rsmu class");
+		return err;
+	}
+
+	err = alloc_chrdev_region(&rsmu_cdevt, 0, DRIVER_MAX_DEV, DRIVER_NAME);
+	if (err < 0) {
+		pr_err("Unable to get major number");
+		goto err_rsmu_class;
+	}
+
+	err = platform_driver_register(&rsmu_driver);
+	if (err < 0) {
+		pr_err("Unabled to register %s driver", DRIVER_NAME);
+		goto err_rsmu_drv;
+	}
+	return 0;
+
+	/* Error Path */
+err_rsmu_drv:
+	unregister_chrdev_region(rsmu_cdevt, DRIVER_MAX_DEV);
+err_rsmu_class:
+	class_destroy(rsmu_class);
+	return err;
+}
+
+static void __exit rsmu_exit(void)
+{
+	platform_driver_unregister(&rsmu_driver);
+	unregister_chrdev_region(rsmu_cdevt, DRIVER_MAX_DEV);
+	class_destroy(rsmu_class);
+	rsmu_class = NULL;
+}
+
+module_init(rsmu_init);
+module_exit(rsmu_exit);
+
+MODULE_DESCRIPTION("Renesas SMU character device driver");
+MODULE_LICENSE("GPL");
diff --git a/drivers/misc/rsmu_cdev.h b/drivers/misc/rsmu_cdev.h
new file mode 100644
index 000000000..0521f1aed
--- /dev/null
+++ b/drivers/misc/rsmu_cdev.h
@@ -0,0 +1,74 @@
+/* SPDX-License-Identifier: GPL-2.0+ */
+/*
+ * This driver is developed for the IDT ClockMatrix(TM) of
+ * timing and synchronization devices.
+ *
+ * Copyright (C) 2019 Integrated Device Technology, Inc., a Renesas Company.
+ */
+#ifndef __LINUX_RSMU_CDEV_H
+#define __LINUX_RSMU_CDEV_H
+
+#include <linux/cdev.h>
+
+struct rsmu_ops;
+
+/**
+ * struct rsmu_cdev - Driver data for RSMU character device
+ * @dev: pointer to platform device
+ * @mfd: pointer to MFD device
+ * @rsmu_cdev: character device handle
+ * @lock: mutex to protect operations from being interrupted
+ * @type: rsmu device type
+ * @ops: rsmu device methods
+ * @index: rsmu device index
+ */
+struct rsmu_cdev {
+	struct device *dev;
+	struct device *mfd;
+	struct cdev rsmu_cdev;
+	struct mutex *lock;
+	enum rsmu_type type;
+	struct rsmu_ops *ops;
+	u8 index;
+};
+
+extern struct rsmu_ops cm_ops;
+extern struct rsmu_ops sabre_ops;
+
+struct rsmu_ops {
+	enum rsmu_type type;
+	int (*set_combomode)(struct rsmu_cdev *rsmu, u8 dpll, u8 mode);
+	int (*get_dpll_state)(struct rsmu_cdev *rsmu, u8 dpll, u8 *state);
+	int (*get_dpll_ffo)(struct rsmu_cdev *rsmu, u8 dpll,
+			    struct rsmu_get_ffo *ffo);
+	int (*get_reg_val)(struct rsmu_cdev *rsmu, struct rsmu_regval *reg_info);
+	int (*set_reg_val)(struct rsmu_cdev *rsmu, struct rsmu_regval *reg_info);
+};
+
+/**
+ * Enumerated type listing DPLL combination modes
+ */
+enum rsmu_dpll_combomode {
+	E_COMBOMODE_CURRENT = 0,
+	E_COMBOMODE_FASTAVG,
+	E_COMBOMODE_SLOWAVG,
+	E_COMBOMODE_HOLDOVER,
+	E_COMBOMODE_MAX
+};
+
+/**
+ * An id used to identify the respective child class states.
+ */
+enum rsmu_class_state {
+	E_SRVLOINITIALSTATE = 0,
+	E_SRVLOUNQUALIFIEDSTATE = 1,
+	E_SRVLOLOCKACQSTATE = 2,
+	E_SRVLOFREQUENCYLOCKEDSTATE = 3,
+	E_SRVLOTIMELOCKEDSTATE = 4,
+	E_SRVLOHOLDOVERINSPECSTATE = 5,
+	E_SRVLOHOLDOVEROUTOFSPECSTATE = 6,
+	E_SRVLOFREERUNSTATE = 7,
+	E_SRVNUMBERLOSTATES = 8,
+	E_SRVLOSTATEINVALID = 9,
+};
+#endif
diff --git a/drivers/misc/rsmu_cm.c b/drivers/misc/rsmu_cm.c
new file mode 100644
index 000000000..cd0f234d5
--- /dev/null
+++ b/drivers/misc/rsmu_cm.c
@@ -0,0 +1,190 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * This driver is developed for the IDT ClockMatrix(TM) of
+ * timing and synchronization devices.
+ *
+ * Copyright (C) 2019 Integrated Device Technology, Inc., a Renesas Company.
+ */
+#include <linux/kernel.h>
+#include <linux/errno.h>
+#include <linux/device.h>
+#include <linux/mfd/idt8a340_reg.h>
+#include <linux/mfd/rsmu.h>
+#include <uapi/linux/rsmu.h>
+#include <asm/unaligned.h>
+
+#include "rsmu_cdev.h"
+
+static int rsmu_cm_set_combomode(struct rsmu_cdev *rsmu, u8 dpll, u8 mode)
+{
+	u16 dpll_ctrl_n;
+	u8 cfg;
+	int err;
+
+	switch (dpll) {
+	case 0:
+		dpll_ctrl_n = DPLL_CTRL_0;
+		break;
+	case 1:
+		dpll_ctrl_n = DPLL_CTRL_1;
+		break;
+	case 2:
+		dpll_ctrl_n = DPLL_CTRL_2;
+		break;
+	case 3:
+		dpll_ctrl_n = DPLL_CTRL_3;
+		break;
+	case 4:
+		dpll_ctrl_n = DPLL_CTRL_4;
+		break;
+	case 5:
+		dpll_ctrl_n = DPLL_CTRL_5;
+		break;
+	case 6:
+		dpll_ctrl_n = DPLL_CTRL_6;
+		break;
+	case 7:
+		dpll_ctrl_n = DPLL_CTRL_7;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	if (mode >= E_COMBOMODE_MAX)
+		return -EINVAL;
+
+	err = rsmu_read(rsmu->mfd, dpll_ctrl_n + DPLL_CTRL_COMBO_MASTER_CFG,
+			&cfg, sizeof(cfg));
+	if (err)
+		return err;
+
+	/* Only need to enable/disable COMBO_MODE_HOLD. */
+	if (mode)
+		cfg |= COMBO_MASTER_HOLD;
+	else
+		cfg &= ~COMBO_MASTER_HOLD;
+
+	return rsmu_write(rsmu->mfd, dpll_ctrl_n + DPLL_CTRL_COMBO_MASTER_CFG,
+			  &cfg, sizeof(cfg));
+}
+
+static int rsmu_cm_get_dpll_state(struct rsmu_cdev *rsmu, u8 dpll, u8 *state)
+{
+	u8 cfg;
+	int err;
+
+	/* 8 is sys dpll */
+	if (dpll > 8)
+		return -EINVAL;
+
+	err = rsmu_read(rsmu->mfd,
+			  STATUS + DPLL0_STATUS + dpll,
+			  &cfg, sizeof(cfg));
+	if (err)
+		return err;
+
+	switch (cfg & DPLL_STATE_MASK) {
+	case DPLL_STATE_FREERUN:
+		*state = E_SRVLOUNQUALIFIEDSTATE;
+		break;
+	case DPLL_STATE_LOCKACQ:
+	case DPLL_STATE_LOCKREC:
+		*state = E_SRVLOLOCKACQSTATE;
+		break;
+	case DPLL_STATE_LOCKED:
+		*state = E_SRVLOTIMELOCKEDSTATE;
+		break;
+	case DPLL_STATE_HOLDOVER:
+		*state = E_SRVLOHOLDOVERINSPECSTATE;
+		break;
+	default:
+		*state = E_SRVLOSTATEINVALID;
+		break;
+	}
+
+	return 0;
+}
+
+static int rsmu_cm_get_dpll_ffo(struct rsmu_cdev *rsmu, u8 dpll,
+				struct rsmu_get_ffo *ffo)
+{
+	u8 buf[8] = {0};
+	s64 fcw = 0;
+	u16 dpll_filter_status;
+	int err;
+
+	switch (dpll) {
+	case 0:
+		dpll_filter_status = DPLL0_FILTER_STATUS;
+		break;
+	case 1:
+		dpll_filter_status = DPLL1_FILTER_STATUS;
+		break;
+	case 2:
+		dpll_filter_status = DPLL2_FILTER_STATUS;
+		break;
+	case 3:
+		dpll_filter_status = DPLL3_FILTER_STATUS;
+		break;
+	case 4:
+		dpll_filter_status = DPLL4_FILTER_STATUS;
+		break;
+	case 5:
+		dpll_filter_status = DPLL5_FILTER_STATUS;
+		break;
+	case 6:
+		dpll_filter_status = DPLL6_FILTER_STATUS;
+		break;
+	case 7:
+		dpll_filter_status = DPLL7_FILTER_STATUS;
+		break;
+	case 8:
+		dpll_filter_status = DPLLSYS_FILTER_STATUS;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	err = rsmu_read(rsmu->mfd, STATUS + dpll_filter_status, buf, 6);
+	if (err)
+		return err;
+
+	/* Convert to frequency control word */
+	fcw = sign_extend64(get_unaligned_le64(buf), 47);
+
+	/* FCW unit is 2 ^ -53 = 1.1102230246251565404236316680908e-16 */
+	ffo->ffo = fcw * 111;
+
+	return 0;
+}
+
+static int rsmu_cm_get_reg_val(struct rsmu_cdev *rsmu, struct rsmu_regval *reg_info)
+{
+	int err;
+
+	err = rsmu_read(rsmu->mfd, reg_info->reg_addr, (u8 *)&reg_info->value, 4);
+	if (err)
+		return err;
+
+	return 0;
+}
+
+static int rsmu_cm_set_reg_val(struct rsmu_cdev *rsmu, struct rsmu_regval *reg_info)
+{
+	int err;
+
+	err = rsmu_write(rsmu->mfd, reg_info->reg_addr, (u8 *)&reg_info->value, 4);
+	if (err)
+		return err;
+
+	return 0;
+}
+
+struct rsmu_ops cm_ops = {
+	.type = RSMU_CM,
+	.set_combomode = rsmu_cm_set_combomode,
+	.get_dpll_state = rsmu_cm_get_dpll_state,
+	.get_dpll_ffo = rsmu_cm_get_dpll_ffo,
+	.get_reg_val = rsmu_cm_get_reg_val,
+	.set_reg_val = rsmu_cm_set_reg_val,
+};
diff --git a/drivers/misc/rsmu_sabre.c b/drivers/misc/rsmu_sabre.c
new file mode 100644
index 000000000..2abe18769
--- /dev/null
+++ b/drivers/misc/rsmu_sabre.c
@@ -0,0 +1,145 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * This driver is developed for the IDT 82P33XXX series of
+ * timing and synchronization devices.
+ *
+ * Copyright (C) 2019 Integrated Device Technology, Inc., a Renesas Company.
+ */
+#include <linux/kernel.h>
+#include <linux/errno.h>
+#include <linux/device.h>
+#include <linux/mfd/idt82p33_reg.h>
+#include <linux/mfd/rsmu.h>
+#include <uapi/linux/rsmu.h>
+#include <asm/unaligned.h>
+
+#include "rsmu_cdev.h"
+
+static int rsmu_sabre_set_combomode(struct rsmu_cdev *rsmu, u8 dpll, u8 mode)
+{
+	u16 dpll_ctrl_n;
+	u8 cfg;
+	int err;
+
+	switch (dpll) {
+	case 0:
+		dpll_ctrl_n = DPLL1_OPERATING_MODE_CNFG;
+		break;
+	case 1:
+		dpll_ctrl_n = DPLL2_OPERATING_MODE_CNFG;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	if (mode >= E_COMBOMODE_MAX)
+		return -EINVAL;
+
+	err = rsmu_read(rsmu->mfd, dpll_ctrl_n, &cfg, sizeof(cfg));
+	if (err)
+		return err;
+
+	cfg &= ~(COMBO_MODE_MASK << COMBO_MODE_SHIFT);
+	cfg |= mode << COMBO_MODE_SHIFT;
+
+	return rsmu_write(rsmu->mfd, dpll_ctrl_n, &cfg, sizeof(cfg));
+}
+
+static int rsmu_sabre_get_dpll_state(struct rsmu_cdev *rsmu, u8 dpll, u8 *state)
+{
+	u16 dpll_sts_n;
+	u8 cfg;
+	int err;
+
+	switch (dpll) {
+	case 0:
+		dpll_sts_n = DPLL1_OPERATING_STS;
+		break;
+	case 1:
+		dpll_sts_n = DPLL2_OPERATING_STS;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	err = rsmu_read(rsmu->mfd, dpll_sts_n, &cfg, sizeof(cfg));
+	if (err)
+		return err;
+
+	switch (cfg & OPERATING_STS_MASK) {
+	case DPLL_STATE_FREERUN:
+		*state = E_SRVLOUNQUALIFIEDSTATE;
+		break;
+	case DPLL_STATE_PRELOCKED2:
+	case DPLL_STATE_PRELOCKED:
+		*state = E_SRVLOLOCKACQSTATE;
+		break;
+	case DPLL_STATE_LOCKED:
+		*state = E_SRVLOTIMELOCKEDSTATE;
+		break;
+	case DPLL_STATE_HOLDOVER:
+		*state = E_SRVLOHOLDOVERINSPECSTATE;
+		break;
+	default:
+		*state = E_SRVLOSTATEINVALID;
+		break;
+	}
+
+	return 0;
+}
+
+static int rsmu_sabre_get_dpll_ffo(struct rsmu_cdev *rsmu, u8 dpll,
+				   struct rsmu_get_ffo *ffo)
+{
+	u8 buf[8] = {0};
+	s64 fcw = 0;
+	u16 dpll_freq_n;
+	int err;
+
+	/* 
+	 * IDTDpll_GetCurrentDpllFreqOffset retrieves the FFO integrator only. 
+	 * In order to get Proportional + Integrator, use the holdover FFO with
+	 * the filter bandwidth 0.5 Hz set by TCS file.
+	 */
+	switch (dpll) {
+	case 0:
+		dpll_freq_n = DPLL1_HOLDOVER_FREQ_CNFG;
+		break;
+	case 1:
+		dpll_freq_n = DPLL2_HOLDOVER_FREQ_CNFG;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	err = rsmu_read(rsmu->mfd, dpll_freq_n, buf, 5);
+	if (err)
+		return err;
+
+	/* Convert to frequency control word */
+	fcw = sign_extend64(get_unaligned_le64(buf), 39);
+
+	/* FCW unit is 77760 / ( 1638400 * 2^48) = 1.68615121864946 * 10^-16 */
+	ffo->ffo = div_s64(fcw * 2107689, 12500);
+
+	return 0;
+}
+
+static int rsmu_sabre_get_reg_val(struct rsmu_cdev *rsmu, struct rsmu_regval *reg_info)
+{
+	int err;
+
+	/* int rsmu_read(struct device *dev, u16 reg, u8 *buf, u16 size) */
+	err = rsmu_read(rsmu->mfd, reg_info->reg_addr, (u8 *)&reg_info->value, 4);
+	if (err)
+		return err;
+
+	return 0;
+}
+
+struct rsmu_ops sabre_ops = {
+	.type = RSMU_SABRE,
+	.set_combomode = rsmu_sabre_set_combomode,
+	.get_dpll_state = rsmu_sabre_get_dpll_state,
+	.get_dpll_ffo = rsmu_sabre_get_dpll_ffo,
+};
