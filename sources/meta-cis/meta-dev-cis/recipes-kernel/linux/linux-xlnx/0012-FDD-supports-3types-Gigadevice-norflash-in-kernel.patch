Subject: [PATCH] [FDD] supports 3types Gigadevice norflash in kernel

---
 drivers/mtd/spi-nor/gigadevice.c | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/drivers/mtd/spi-nor/gigadevice.c b/drivers/mtd/spi-nor/gigadevice.c
index 86b5ace62..5f7b74021 100644
--- a/drivers/mtd/spi-nor/gigadevice.c
+++ b/drivers/mtd/spi-nor/gigadevice.c
@@ -92,6 +92,18 @@ static const struct flash_info gigadevice_parts[] = {
 			      SECT_4K | USE_FSR | SPI_NOR_OCTAL_READ |
 			      SPI_NOR_OCTAL_WRITE | SPI_NOR_4B_OPCODES)
 		.fixups = &gd25lx256e_fixups },
+       { "gd55b02ge",  INFO(0xc8471c, 0, 64 * 1024, 4096,
+                          SECT_4K | SPI_NOR_DUAL_READ | SPI_NOR_QUAD_READ |
+                          SPI_NOR_HAS_LOCK | SPI_NOR_HAS_TB |
+                          SPI_NOR_4B_OPCODES) },
+       { "gd25b256me", INFO(0xc8471a, 0, 64 * 1024, 1024,
+                          SECT_4K | SPI_NOR_DUAL_READ | SPI_NOR_QUAD_READ |
+                          SPI_NOR_HAS_LOCK | SPI_NOR_HAS_TB |
+                          SPI_NOR_4B_OPCODES) },
+       { "gd55b01ge", INFO(0xc8471b, 0, 64 * 1024, 2048,
+                          SECT_4K | SPI_NOR_DUAL_READ | SPI_NOR_QUAD_READ |
+                          SPI_NOR_HAS_LOCK | SPI_NOR_HAS_TB |
+                          SPI_NOR_4B_OPCODES) },
 };
 
 const struct spi_nor_manufacturer spi_nor_gigadevice = {
